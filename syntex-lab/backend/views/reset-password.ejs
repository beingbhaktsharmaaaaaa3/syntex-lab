<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %></title><link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="auth-page">
  <div class="auth-side" style="max-width:340px;"><h1>Set New Password</h1><p>Choose a strong, unique password for your account.</p></div>
  <div class="auth-form-side">
    <div class="auth-form-box">
      <h2>Reset your password</h2>
      <p>Enter and confirm your new password below.</p>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <form action="/reset-password" method="POST">
        <input type="hidden" name="token" value="<%= token %>">
        <div class="form-group"><label>New Password<span class="form-required">*</span></label><input type="password" name="password" placeholder="New password" required></div>
        <div class="form-group"><label>Confirm Password<span class="form-required">*</span></label><input type="password" name="confirm_password" placeholder="Repeat password" required></div>
        <button type="submit" class="btn btn-primary w-100">Update Password</button>
      </form>
      <div class="auth-footer"><a href="/login">← Back to sign in</a></div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
