<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">User Profile</span>
      <div class="header-right">
        <% if (isOwner) { %><a href="/profile/<%= profile.id %>/edit" class="btn btn-primary btn-sm">Edit Profile</a><% } %>
        <a href="/profile/<%= user.id %>" class="header-user">
          <div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div>
        </a>
      </div>
    </div>
    <div class="page-body">
      <div class="breadcrumb"><a href="/dashboard">Dashboard</a><span>›</span><span>Profile #<%= profile.id %></span></div>

      <div class="grid-2" style="align-items:start;">
        <div>
          <div class="card mb-4">
            <div class="card-header">
              <h3>Account Information</h3>
              <span class="badge badge-<%= profile.role === 'admin' ? 'admin' : profile.role === 'developer' ? 'dev' : 'gray' %>"><%= profile.role %></span>
            </div>
            <div class="card-body">
              <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
                <div style="width:64px;height:64px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;color:#fff;flex-shrink:0;">
                  <%= ((profile.first_name||profile.username).charAt(0)).toUpperCase() %>
                </div>
                <div>
                  <div style="font-size:18px;font-weight:700;"><%= profile.first_name %> <%= profile.last_name %></div>
                  <div style="color:var(--text-muted);font-size:13px;">@<%= profile.username %></div>
                  <div style="color:var(--text-muted);font-size:12px;"><%= profile.job_title %> · <%= profile.department %></div>
                </div>
              </div>
              <table style="width:100%;font-size:13px;">
                <tr><td style="padding:6px 0;color:var(--text-muted);width:120px;">Email</td><td><%= profile.email %></td></tr>
                <tr><td style="padding:6px 0;color:var(--text-muted);">Phone</td><td><%= profile.phone || '—' %></td></tr>
                <tr><td style="padding:6px 0;color:var(--text-muted);">Department</td><td><%= profile.department || '—' %></td></tr>
                <tr><td style="padding:6px 0;color:var(--text-muted);">Member since</td><td><%= new Date(profile.created_at).toLocaleDateString() %></td></tr>
                <tr><td style="padding:6px 0;color:var(--text-muted);">Last login</td><td><%= profile.last_login ? new Date(profile.last_login).toLocaleString() : '—' %></td></tr>
              </table>
            </div>
          </div>

          <div class="card mb-4">
            <div class="card-header"><h3>Bio</h3></div>
            <div class="card-body">
              <% if (profile.bio) { %>
                <!-- VULNERABILITY: Stored XSS — bio rendered without HTML encoding -->
                <div style="font-size:13px;line-height:1.7;"><%- profile.bio %></div>
              <% } else { %>
                <p class="text-muted" style="font-size:13px;">No bio provided.</p>
              <% } %>
            </div>
          </div>
        </div>

        <div>
          <!-- VULNERABILITY: IDOR — api_key and secret_note visible to ANY authenticated user, not just owner -->
          <div class="card mb-4" style="border-color:#FDE68A;">
            <div class="card-header" style="background:#FFFBEB;">
              <h3>API Credentials</h3>
              <span class="badge badge-warning">Sensitive</span>
            </div>
            <div class="card-body">
              <div class="form-group">
                <label>API Key</label>
                <input type="text" value="<%= profile.api_key || 'Not set' %>" readonly style="font-family:monospace;font-size:12px;background:#F9FAFB;">
              </div>
              <% if (profile.secret_note) { %>
              <div class="form-group">
                <label>Private Notes</label>
                <!-- VULNERABILITY: IDOR — any auth'd user can read private notes -->
                <textarea readonly style="font-size:12px;background:#F9FAFB;font-family:monospace;"><%= profile.secret_note %></textarea>
              </div>
              <% } %>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><h3>Recent Orders</h3><a href="/orders" class="btn btn-secondary btn-sm">All orders</a></div>
            <div class="table-wrapper">
              <table>
                <thead><tr><th>Invoice</th><th>Product</th><th>Status</th></tr></thead>
                <tbody>
                  <% if (recentOrders && recentOrders.length > 0) { %>
                    <% recentOrders.forEach(o => { %>
                    <tr>
                      <td><a href="/orders/<%= o.id %>" style="color:var(--accent);text-decoration:none;"><%= o.invoice_number %></a></td>
                      <td style="font-size:12px;"><%= o.product_name %></td>
                      <td><span class="badge badge-<%= o.status==='active'?'success':o.status==='pending'?'warning':'gray' %>"><%= o.status %></span></td>
                    </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="3" class="text-muted text-center" style="padding:16px;">No orders.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
