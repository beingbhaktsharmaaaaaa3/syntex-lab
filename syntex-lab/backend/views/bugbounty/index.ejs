<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Bug Bounty Program</span>
      <div class="header-right">
        <a href="/program/submit" class="btn btn-primary btn-sm">+ Submit Report</a>
        <% if (locals.user) { %><a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a><% } %>
      </div>
    </div>

    <div class="page-body">
      <!-- Program Header -->
      <div class="card mb-4" style="background:linear-gradient(135deg,#1B3A6B 0%,#2D5E8E 100%);color:#fff;border:none;">
        <div class="card-body" style="padding:32px;">
          <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;">
            <div style="width:64px;height:64px;background:rgba(255,255,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:800;">S</div>
            <div style="flex:1;">
              <h1 style="font-size:22px;font-weight:800;margin-bottom:4px;">Syntex Solutions Bug Bounty</h1>
              <p style="opacity:0.75;font-size:13px;">Managed Program · Private Invitations · Launched Jan 2023</p>
              <div style="display:flex;gap:12px;margin-top:10px;flex-wrap:wrap;">
                <span style="background:rgba(255,255,255,0.15);padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;">✓ Bounties Paid</span>
                <span style="background:rgba(255,255,255,0.15);padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;">✓ Safe Harbour</span>
                <span style="background:rgba(255,255,255,0.15);padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;">✓ No Legal Action</span>
              </div>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <a href="/program/submit" style="background:#fff;color:var(--primary);padding:10px 20px;border-radius:6px;font-weight:700;font-size:13px;text-decoration:none;">Submit a Report →</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats Row -->
      <div class="stats-grid mb-4">
        <div class="stat-card"><div class="stat-label">Total Reports</div><div class="stat-value"><%= stats.total_reports %></div><div class="stat-meta">All time submissions</div></div>
        <div class="stat-card"><div class="stat-label">Accepted</div><div class="stat-value"><%= stats.accepted %></div><div class="stat-meta">Valid unique bugs</div></div>
        <div class="stat-card"><div class="stat-label">Total Paid</div><div class="stat-value">$<%= parseFloat(stats.total_paid||0).toLocaleString() %></div><div class="stat-meta">Bounties awarded</div></div>
        <div class="stat-card"><div class="stat-label">Critical Bugs</div><div class="stat-value"><%= stats.critical_count %></div><div class="stat-meta">P1 severity findings</div></div>
      </div>

      <div class="grid-2" style="align-items:start;gap:24px;">
        <div>
          <!-- Severity & Rewards -->
          <div class="card mb-4">
            <div class="card-header"><h3>Severity Levels & Rewards</h3></div>
            <div class="table-wrapper">
              <table>
                <thead><tr><th>Level</th><th>Severity</th><th>CVSS</th><th>Examples</th><th>Reward Range</th></tr></thead>
                <tbody>
                  <tr>
                    <td><span class="badge" style="background:#FEE2E2;color:#991B1B;font-size:12px;">P1</span></td>
                    <td style="font-weight:700;color:#B91C1C;">Critical</td>
                    <td>9.0 – 10.0</td>
                    <td style="font-size:12px;">RCE, auth bypass to admin, mass data dump, SQLi with exfil</td>
                    <td style="font-weight:700;color:#15803D;">$1,000 – $3,000</td>
                  </tr>
                  <tr>
                    <td><span class="badge" style="background:#FEF3C7;color:#92400E;font-size:12px;">P2</span></td>
                    <td style="font-weight:700;color:#B45309;">High</td>
                    <td>7.0 – 8.9</td>
                    <td style="font-size:12px;">Stored XSS → admin, SSRF internal, IDOR with PII, JWT bypass</td>
                    <td style="font-weight:700;color:#15803D;">$500 – $1,000</td>
                  </tr>
                  <tr>
                    <td><span class="badge" style="background:#FEF9C3;color:#713F12;font-size:12px;">P3</span></td>
                    <td style="font-weight:700;color:#D97706;">Medium</td>
                    <td>4.0 – 6.9</td>
                    <td style="font-size:12px;">CSRF, reflected XSS, IDOR non-sensitive, open redirect</td>
                    <td style="font-weight:700;color:#15803D;">$100 – $500</td>
                  </tr>
                  <tr>
                    <td><span class="badge" style="background:#ECFDF5;color:#065F46;font-size:12px;">P4</span></td>
                    <td style="font-weight:700;color:#047857;">Low</td>
                    <td>0.1 – 3.9</td>
                    <td style="font-size:12px;">Info disclosure, missing headers, rate limit, predictable token</td>
                    <td style="font-weight:700;color:#15803D;">$50 – $100</td>
                  </tr>
                  <tr>
                    <td><span class="badge badge-gray" style="font-size:12px;">P5</span></td>
                    <td style="color:var(--text-muted);">Informative</td>
                    <td>N/A</td>
                    <td style="font-size:12px;">Best practices, spelling, minor UX, version disclosure</td>
                    <td style="color:var(--text-muted);">$0 (acknowledged)</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Response Times -->
          <div class="card mb-4">
            <div class="card-header"><h3>Response Times (SLA)</h3></div>
            <div class="table-wrapper">
              <table>
                <thead><tr><th>Severity</th><th>First Response</th><th>Triage</th><th>Resolution</th></tr></thead>
                <tbody>
                  <tr><td><span class="badge" style="background:#FEE2E2;color:#991B1B;">P1 Critical</span></td><td>4 hours</td><td>24 hours</td><td>7 days</td></tr>
                  <tr><td><span class="badge" style="background:#FEF3C7;color:#92400E;">P2 High</span></td><td>24 hours</td><td>3 days</td><td>30 days</td></tr>
                  <tr><td><span class="badge" style="background:#FEF9C3;color:#713F12;">P3 Medium</span></td><td>3 days</td><td>7 days</td><td>60 days</td></tr>
                  <tr><td><span class="badge" style="background:#ECFDF5;color:#065F46;">P4 Low</span></td><td>7 days</td><td>14 days</td><td>90 days</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Report Format -->
          <div class="card">
            <div class="card-header"><h3>What Makes a Good Report</h3></div>
            <div class="card-body" style="font-size:13px;line-height:1.8;">
              <p style="margin-bottom:12px;">Reports that get accepted and paid quickly all share these qualities:</p>
              <div style="display:flex;flex-direction:column;gap:8px;">
                <div style="display:flex;gap:10px;"><span style="color:var(--success);font-weight:700;flex-shrink:0;">✓</span><span><strong>Clear title</strong> — "[Vuln Type] in [Feature] allows [Impact]"</span></div>
                <div style="display:flex;gap:10px;"><span style="color:var(--success);font-weight:700;flex-shrink:0;">✓</span><span><strong>Numbered steps</strong> — reproducible by the triage team in under 5 minutes</span></div>
                <div style="display:flex;gap:10px;"><span style="color:var(--success);font-weight:700;flex-shrink:0;">✓</span><span><strong>Proof of concept</strong> — screenshot, Burp capture, or video</span></div>
                <div style="display:flex;gap:10px;"><span style="color:var(--success);font-weight:700;flex-shrink:0;">✓</span><span><strong>Real-world impact</strong> — what can an attacker actually do with this?</span></div>
                <div style="display:flex;gap:10px;"><span style="color:var(--success);font-weight:700;flex-shrink:0;">✓</span><span><strong>Suggested fix</strong> — shows professionalism, gets noticed</span></div>
                <div style="display:flex;gap:10px;"><span style="color:var(--danger);font-weight:700;flex-shrink:0;">✗</span><span><strong>Do not</strong> submit scanner output without manual verification</span></div>
                <div style="display:flex;gap:10px;"><span style="color:var(--danger);font-weight:700;flex-shrink:0;">✗</span><span><strong>Do not</strong> over-inflate severity — it hurts your credibility</span></div>
              </div>
            </div>
          </div>
        </div>

        <div>
          <!-- In Scope -->
          <div class="card mb-4">
            <div class="card-header"><h3>In-Scope Assets</h3><a href="/bug-bounty/scope" class="btn btn-secondary btn-sm">Full Scope →</a></div>
            <div class="card-body" style="padding:0 20px;">
              <% const inscope = [
                {asset:'syntex.local',desc:'Main application — all features'},
                {asset:'api.syntex.local',desc:'REST API v1 and v2'},
                {asset:'admin.syntex.local',desc:'Admin panel proxy'},
                {asset:'staging.syntex.local',desc:'Staging environment'},
                {asset:'dev.syntex.local',desc:'Development environment'},
                {asset:'*.syntex.local',desc:'All subdomains unless listed as out-of-scope'},
              ]; %>
              <% inscope.forEach(a => { %>
              <div style="display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-light);">
                <span style="color:var(--success);font-weight:700;flex-shrink:0;">✓</span>
                <div><code style="font-size:12px;"><%= a.asset %></code><div style="font-size:12px;color:var(--text-muted);"><%= a.desc %></div></div>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- Out of Scope -->
          <div class="card mb-4">
            <div class="card-header"><h3>Out-of-Scope</h3></div>
            <div class="card-body" style="padding:0 20px;">
              <% const outscope = [
                'mail.syntex.local — email infrastructure',
                'vpn.syntex.local — VPN gateway',
                'DoS / DDoS attacks of any kind',
                'Social engineering of staff or users',
                'Physical security testing',
                'Attacks on third-party services',
                'Automated scanning without manual verification',
              ]; %>
              <% outscope.forEach(a => { %>
              <div style="display:flex;gap:12px;padding:8px 0;border-bottom:1px solid var(--border-light);">
                <span style="color:var(--danger);font-weight:700;flex-shrink:0;">✗</span>
                <span style="font-size:12px;"><%= a %></span>
              </div>
              <% }) %>
            </div>
          </div>

          <!-- Hall of Fame Preview -->
          <div class="card mb-4">
            <div class="card-header"><h3>Top Researchers</h3><a href="/program/hall-of-fame" class="btn btn-secondary btn-sm">Full HoF →</a></div>
            <div class="table-wrapper">
              <table>
                <thead><tr><th>#</th><th>Researcher</th><th>Bugs</th><th>Bounty</th></tr></thead>
                <tbody>
                  <% hof.forEach((r,i) => { %>
                  <tr>
                    <td style="font-weight:700;color:var(--text-muted);">#<%= r.rank %></td>
                    <td>
                      <div style="font-weight:600;font-size:13px;"><%= r.researcher_name %></div>
                      <div style="font-size:11px;color:var(--text-muted);">@<%= r.handle %></div>
                    </td>
                    <td><span class="badge badge-info"><%= r.bugs_found %></span></td>
                    <td style="font-weight:600;color:var(--success);">$<%= parseFloat(r.total_bounty).toLocaleString() %></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Quick Links -->
          <div class="card">
            <div class="card-header"><h3>Resources</h3></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
              <a href="/program/submit" class="btn btn-primary">Submit a Bug Report</a>
              <a href="/bug-bounty/scope" class="btn btn-secondary">Full Scope & Rules</a>
              <a href="/program/challenges" class="btn btn-secondary">Practice: Vuln Chains</a>
              <a href="/program/hints" class="btn btn-secondary">Hint System</a>
              <a href="/program/hall-of-fame" class="btn btn-secondary">Hall of Fame</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
