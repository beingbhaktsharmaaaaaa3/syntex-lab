<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">Hall of Fame</span>
      <div class="header-right"><a href="/reports/new" class="btn btn-primary btn-sm">+ Submit Report</a>
        <% if(locals.user){%><a href="/profile/<%=user.id%>" class="header-user"><div class="header-avatar"><%=((user.first_name||user.username).charAt(0)).toUpperCase()%></div></a><%}%>
      </div>
    </div>
    <div class="page-body">
      <div class="breadcrumb"><a href="/bug-bounty">Bug Bounty</a><span>›</span><span>Hall of Fame</span></div>
      <div class="page-header">
        <h1>Hall of Fame</h1>
        <p>Recognising the security researchers who help keep Syntex Solutions secure.</p>
      </div>

      <!-- Top 3 podium -->
      <div style="display:flex;justify-content:center;align-items:flex-end;gap:20px;margin-bottom:32px;flex-wrap:wrap;">
        <%
          const top3 = hof.slice(0,3);
          const order = [1,0,2]; // silver, gold, bronze
          const heights = [140,180,120];
          const colors = ['#9CA3AF','#F59E0B','#CD7F32'];
          const labels = ['2nd','1st','3rd'];
        %>
        <% order.forEach((idx,pos) => {
          const r = top3[idx];
          if(!r) return;
        %>
        <div style="text-align:center;display:flex;flex-direction:column;align-items:center;gap:8px;">
          <div style="width:52px;height:52px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:#fff;border:3px solid <%=colors[pos]%>;">
            <%=(r.researcher_name).charAt(0)%>
          </div>
          <div style="font-size:13px;font-weight:700;"><%=r.researcher_name%></div>
          <div style="font-size:11px;color:var(--text-muted);">@<%=r.handle%></div>
          <div style="width:80px;background:<%=colors[pos]%>;border-radius:6px 6px 0 0;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:14px;" style="height:<%=heights[pos]%>px;">
            <div style="padding:12px 8px;text-align:center;min-height:<%=heights[pos]%>px;display:flex;flex-direction:column;align-items:center;justify-content:center;">
              <div style="font-size:18px;"><%=labels[pos]%></div>
              <div style="font-size:11px;opacity:0.9;">$<%=parseFloat(r.total_bounty).toLocaleString()%></div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Full leaderboard -->
      <div class="card">
        <div class="card-header"><h3>All Researchers</h3></div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Rank</th><th>Researcher</th><th>Country</th><th>Total Bugs</th><th>Critical</th><th>Total Bounty</th><th>Member Since</th></tr></thead>
            <tbody>
              <% hof.forEach(r => { %>
              <tr>
                <td>
                  <% if(r.rank===1){%><span style="font-size:18px;">🥇</span>
                  <%}else if(r.rank===2){%><span style="font-size:18px;">🥈</span>
                  <%}else if(r.rank===3){%><span style="font-size:18px;">🥉</span>
                  <%}else{%><span style="font-weight:700;color:var(--text-muted);">#<%=r.rank%></span><%}%>
                </td>
                <td>
                  <div style="font-weight:700;"><%=r.researcher_name%></div>
                  <div style="font-size:11px;color:var(--accent);">@<%=r.handle%></div>
                </td>
                <td style="font-size:13px;"><%=r.country||'—'%></td>
                <td><span class="badge badge-info"><%=r.bugs_found%></span></td>
                <td><span class="badge badge-danger"><%=r.critical_bugs%></span></td>
                <td style="font-weight:700;color:var(--success);">$<%=parseFloat(r.total_bounty).toLocaleString()%></td>
                <td style="font-size:12px;color:var(--text-muted);"><%=r.joined_year%></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="card-footer" style="font-size:12px;color:var(--text-muted);">
          Want your name here? <a href="/reports/new" style="color:var(--accent);">Submit a valid report</a> to earn recognition.
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
