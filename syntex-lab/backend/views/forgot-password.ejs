<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-side" style="max-width:340px;">
    <h1>Password Reset</h1>
    <p>Enter your account email and we'll send a reset link. The link is valid for 24 hours.</p>
  </div>
  <div class="auth-form-side">
    <div class="auth-form-box">
      <h2>Forgot your password?</h2>
      <p>Enter your registered email address to receive a reset link.</p>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <% if (message) { %><div class="alert alert-info"><%- message %></div><% } %>
      <!-- VULNERABILITY: No rate limiting on this form -->
      <form action="/forgot-password" method="POST">
        <div class="form-group">
          <label>Email Address<span class="form-required">*</span></label>
          <input type="email" name="email" placeholder="you@company.com" required>
          <div class="form-hint">We'll send password reset instructions to this address.</div>
        </div>
        <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
      </form>
      <div class="auth-footer"><a href="/login">← Back to sign in</a></div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
