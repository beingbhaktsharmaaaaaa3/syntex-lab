<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="top-header"><span class="header-title">PostMessage Security Lab</span>
    <div class="header-right"><a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a></div>
  </div>
  <div class="page-body">
    <div class="page-header"><h1>window.postMessage() Security</h1><p>The parent frame below has a listener that doesn't check <code>event.origin</code> before trusting messages.</p></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:960px;align-items:start;">
      <div>
        <div class="card mb-4">
          <iframe id="target-frame" src="/postmessage-demo/parent" style="width:100%;height:220px;border:1px solid var(--border);border-radius:var(--radius);"></iframe>
        </div>
        <div class="card mb-4">
          <div class="card-header"><h3>🟢 Easy — Missing Origin Check</h3></div>
          <div class="card-body">
            <button onclick="sendMessage({action:'steal',data:'leaked'})" class="btn btn-primary" style="width:100%;">Send Message (any origin accepted)</button>
          </div>
        </div>
        <div class="card" style="border-color:var(--warning);">
          <div class="card-header" style="background:#FFFBEB;"><h3>🟡 Medium — targetOrigin: '*' Data Leak</h3></div>
          <div class="card-body" style="font-size:12px;color:var(--text-muted);">
            <p>A vulnerable SENDER using <code>postMessage(data, '*')</code> broadcasts to any listening frame regardless of origin — sensitive data sent this way can be intercepted by a malicious iframe embedded alongside it.</p>
          </div>
        </div>
        <div class="card mt-3" style="border-color:var(--danger);">
          <div class="card-header" style="background:var(--danger-bg);"><h3>🔴 Hard — innerHTML Sink (DOM XSS)</h3></div>
          <div class="card-body">
            <button onclick="sendMessage({html:'<img src=x onerror=alert(document.domain)>'})" class="btn btn-danger" style="width:100%;">Send HTML Payload (XSS via innerHTML)</button>
          </div>
        </div>
      </div>
      <div>
        <div class="card mb-4">
          <div class="card-header"><h3>Vulnerable Listener Code</h3></div>
          <div class="card-body">
            <pre style="font-size:11px;">window.addEventListener('message', function(event) {
  // VULN: missing origin check!
  // Should be: if (event.origin !== 'https://syntex.local') return;

  if (event.data.html) {
    document.body.innerHTML += event.data.html; // XSS sink
  }
});</pre>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Console Output</h3></div>
          <div id="console-log" style="font-family:monospace;font-size:11px;padding:14px;min-height:100px;background:#1A202C;color:#68D391;border-radius:var(--radius);">// Send a message to see results...</div>
        </div>
      </div>
    </div>
  </div>
</main>
</div><%- include('../partials/footer') %>
<script>
function sendMessage(data) {
  const frame = document.getElementById('target-frame');
  // VULNERABILITY: targetOrigin '*' — message sent regardless of receiver's actual origin
  frame.contentWindow.postMessage(data, '*');
  document.getElementById('console-log').textContent += `Sent: ${JSON.stringify(data)}\n`;
  if (data.html) {
    setTimeout(() => {
      document.getElementById('console-log').textContent += '🚩 FLAG{POSTMESSAGE_NO_ORIGIN_CHECK_XSS}\n';
    }, 300);
  }
}
</script>
