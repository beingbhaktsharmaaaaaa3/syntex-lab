<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Create Account — Syntex Solutions</title><link rel="stylesheet" href="/css/style.css"></head>
<body style="background:var(--page-bg);display:flex;align-items:center;justify-content:center;min-height:100vh;">
<div style="width:100%;max-width:480px;padding:24px;">
  <div class="card">
    <div style="padding:28px 28px 0;text-align:center;">
      <div style="width:56px;height:56px;background:var(--primary);border-radius:12px;margin:0 auto 14px;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:800;color:#fff;">S</div>
      <h2 style="font-size:17px;font-weight:700;">Create Your Account</h2>
      <p style="font-size:13px;color:var(--text-muted);">Weak Password Policy Lab</p>
    </div>
    <div class="card-body">
      <% if(result){ %>
        <% if(result.error){ %><div class="alert alert-danger"><%= result.error %></div>
        <% } else if(result.success){ %>
        <div class="alert alert-<%= result.weaknesses.length?'warning':'success' %>">
          ✅ Account created with a <%= result.password_length %>-character password
        </div>
        <% if(result.weaknesses.length){ %>
        <div style="background:var(--danger-bg);border:1px solid var(--danger);border-radius:var(--radius);padding:14px;margin-bottom:14px;">
          <div style="font-weight:700;color:var(--danger);margin-bottom:8px;">⚠️ Weaknesses Detected</div>
          <% result.weaknesses.forEach(w => { %>
          <div style="font-size:12px;margin-bottom:4px;">• <%= w %></div>
          <% }) %>
          <% if(result.flag){ %>
          <div style="margin-top:10px;font-family:monospace;font-size:12px;color:var(--success);">🚩 <%= result.flag %></div>
          <% } %>
        </div>
        <% } %>
        <% } %>
      <% } %>
      <form action="/register-weak" method="POST">
        <div class="form-group"><label>Username</label><input type="text" name="username" required placeholder="testuser123"></div>
        <div class="form-group"><label>Password</label><input type="text" name="password" required placeholder="Try: '1' or 'aaaaaa' or 'Password '"></div>
        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;">Create Account</button>
      </form>
    </div>
  </div>
  
</div>
</body></html>
