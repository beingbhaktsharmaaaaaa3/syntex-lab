<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="top-header">
    <span class="header-title">Invoices</span>
    <div class="header-right">
      <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
    </div>
  </div>
  <div class="page-body">
    <div class="page-header">
      <h1>Invoice Management</h1>
      <p>View and manage your billing invoices.</p>
    </div>
    <!-- VULNERABILITY: Shows ALL invoices regardless of user ownership (IDOR/BOLA) -->
    <div class="card">
      <div class="card-header"><h3>All Invoices</h3><span style="font-size:12px;color:var(--text-muted);"><%= invoices.length %> total</span></div>
      <div class="table-wrapper">
        <table>
          <thead><tr><th>Invoice #</th><th>Company</th><th>Amount</th><th>Status</th><th>Billing Email</th><th>Card</th><th>Date</th><th></th></tr></thead>
          <tbody>
            <% invoices.forEach(inv => { %>
            <tr>
              <td style="font-family:monospace;font-size:12px;"><%= inv.invoice_number %></td>
              <td style="font-weight:600;font-size:13px;"><%= inv.company_name %></td>
              <td style="font-weight:700;color:<%= inv.status==='overdue'?'var(--danger)':inv.status==='pending'?'var(--warning)':'var(--success)' %>;">
                $<%= parseFloat(inv.amount||0).toLocaleString() %>
              </td>
              <td>
                <span class="badge badge-<%= inv.status==='paid'?'success':inv.status==='overdue'?'danger':'warning' %>">
                  <%= inv.status %>
                </span>
              </td>
              <td style="font-size:12px;"><%= inv.billing_email %></td>
              <!-- VULNERABILITY: Card last 4 digits returned for ALL invoices -->
              <td style="font-family:monospace;font-size:12px;">**** **** **** <%= inv.card_last4 %></td>
              <td style="font-size:12px;color:var(--text-muted);"><%= inv.created_at ? new Date(inv.created_at).toLocaleDateString() : '—' %></td>
              <td><a href="/invoices/<%= inv.id %>" class="btn btn-secondary btn-sm">View</a></td>
            </tr>
            <% if(inv.notes){ %>
            <!-- INTERNAL NOTES: <%= inv.notes %> -->
            <% } %>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    
  </div>
</main>
</div><%- include('../partials/footer') %>
