<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">Newsletter Signup</span></div>
    <div class="page-body">
      <div class="page-header"><h1>Subscribe to Our Newsletter</h1></div>
      <div style="max-width:500px;">
        <div class="card">
          <div class="card-body">
            <% if (result === 'subscribed') { %>
            <div class="alert alert-success">Subscribed successfully!</div>
            <% } else if (result === 'injection_detected') { %>
            <div class="alert alert-danger">⚠️ Email Header Injection Detected!</div>
            <% if(flag){ %><div style="margin-top:10px;font-family:monospace;font-size:12px;color:var(--danger);padding:10px;background:var(--danger-bg);border-radius:var(--radius);">🚩 <%= flag %></div><% } %>
            <% } %>
            <form action="/newsletter" method="POST">
              <div class="form-group"><label>Your Name</label><input type="text" name="name" value="<%= locals.name||'' %>" placeholder="John Smith"></div>
              <div class="form-group"><label>Email Address</label><input type="email" name="email" value="<%= locals.email||'' %>" required placeholder="john@company.com"></div>
              <button type="submit" class="btn btn-primary">Subscribe</button>
            </form>
            <% if(locals.simulatedHeader && locals.lab && lab.showHints){ %>
            <div style="margin-top:16px;background:var(--page-bg);border:1px solid var(--border);border-radius:var(--radius);padding:12px;">
              <div style="font-size:11px;font-weight:700;color:var(--text-muted);margin-bottom:6px;">Simulated Email Header:</div>
              <pre style="font-size:11px;"><%= simulatedHeader %></pre>
            </div>
            <% } %>
          </div>
        </div>
        
      </div>
    </div>
  </main>
</div><%- include('../partials/footer') %>
