<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">Profile Update API</span></div>
    <div class="page-body">
      <div class="page-header"><h1>Profile Update</h1><p>Update your profile using the REST API.</p></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;">
        <div>
          <div class="card">
            <div class="card-header"><h3>API Request Builder</h3></div>
            <div class="card-body">
              <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px;">Send a PUT request to <code>/api/v1/profile-update</code> with JSON body.</p>
              <div style="background:var(--page-bg);border:1px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:14px;">
                <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;margin-bottom:8px;">Normal Request</div>
                <pre style="font-size:12px;">curl -X PUT http://syntex.local/api/v1/profile-update \
  -H "Content-Type: application/json" \
  -b "SYNTEX_SESS=..." \
  -d '{"first_name":"John","bio":"Developer"}'</pre>
              </div>
              
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Current Profile</h3></div>
          <div class="card-body">
            <table style="font-size:13px;width:100%;">
              <% ['id','username','email','role','first_name','last_name','department','wallet_balance'].forEach(f => { %>
              <tr><td style="padding:5px 0;color:var(--text-muted);"><%= f %></td><td style="padding:5px 0;font-weight:600;"><%= user[f]||'—' %></td></tr>
              <% }) %>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</div><%- include('../partials/footer') %>
