<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">Config Merge API</span></div>
    <div class="page-body">
      <div class="page-header"><h1>User Config Merge</h1><p>Merge your custom settings with default application config.</p></div>
      <div class="card" style="max-width:640px;">
        <div class="card-header"><h3>Try the Merge API</h3></div>
        <div class="card-body">
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:14px;">POST to <code>/api/v1/merge</code> with a JSON <code>config</code> object.</p>
          <div style="background:var(--page-bg);border:1px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:12px;">
            <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;margin-bottom:8px;">Normal Usage</div>
            <pre style="font-size:12px;">curl -X POST http://syntex.local/api/v1/merge \
  -H "Content-Type: application/json" \
  -b "SYNTEX_SESS=..." \
  -d '{"config":{"theme":"light","language":"fr"}}'</pre>
          </div>
          
        </div>
      </div>
    </div>
  </main>
</div><%- include('../partials/footer') %>
