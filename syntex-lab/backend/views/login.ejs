<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-side">
    <h1>Syntex Solutions</h1>
    <p>Enterprise Resource Management Platform — Powering 4,200+ organizations worldwide.</p>
    <div class="auth-features">
      <div class="auth-feature">
        <div class="auth-feature-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div>
        <div class="auth-feature-text"><strong>ISO 27001 Certified</strong><span>Enterprise-grade security controls</span></div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
        <div class="auth-feature-text"><strong>99.99% Uptime SLA</strong><span>Built for mission-critical workloads</span></div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg></div>
        <div class="auth-feature-text"><strong>Global Infrastructure</strong><span>Data centers across 4 regions</span></div>
      </div>
    </div>
  </div>
  <div class="auth-form-side">
    <div class="auth-form-box">
      <h2>Welcome back</h2>
      <p>Sign in to your Syntex account to continue.</p>

      <% if (error) { %>
      <div class="alert alert-danger">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= error %>
      </div>
      <% } %>

      <!-- VULNERABILITY: No CSRF token -->
      <form action="/login?redirect=<%= redirect %>" method="POST">
        <div class="form-group">
          <label for="username">Username or Email<span class="form-required">*</span></label>
          <input type="text" id="username" name="username" value="<%= typeof username !== 'undefined' ? username : '' %>" placeholder="e.g. john.doe" autocomplete="username" required>
        </div>
        <div class="form-group">
          <label for="password">Password<span class="form-required">*</span></label>
          <input type="password" id="password" name="password" placeholder="Your password" autocomplete="current-password" required>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
          <label class="form-check" style="font-weight:400;font-size:12px;"><input type="checkbox" name="remember"> Remember me for 30 days</label>
          <a href="/forgot-password" style="font-size:12px;color:var(--accent);text-decoration:none;">Forgot password?</a>
        </div>
        <input type="hidden" name="redirect" value="<%= redirect %>">
        <button type="submit" class="btn btn-primary w-100 btn-lg">Sign In</button>
      </form>

      <div class="auth-footer">
        Don't have an account? <a href="/register">Create one free</a>
      </div>

      <hr class="divider">
      <div style="font-size:11px;color:var(--text-light);text-align:center;line-height:1.6;">
        By signing in you agree to our <a href="#" style="color:var(--text-muted);">Terms of Service</a> and <a href="#" style="color:var(--text-muted);">Privacy Policy</a>.
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
