<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : 'Error' %> · Syntex Solutions</title>
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--page-bg);">
  <div style="max-width:680px;width:100%;padding:24px;">
    <div class="card" style="border-color:var(--danger);">
      <div class="card-header" style="background:var(--danger-bg);">
        <div style="display:flex;align-items:center;gap:10px;">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20" style="color:var(--danger);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <h2 style="font-size:15px;color:var(--danger);"><%= typeof status !== 'undefined' ? status : '500' %> — Server Error</h2>
        </div>
      </div>
      <div class="card-body">
        <%# VULNERABILITY: XSS — message rendered without HTML encoding %>
        <%# VULNERABILITY: Information disclosure — raw DB errors, internal paths exposed %>
        <%# VULNERABILITY: Stack trace always shown — reveals file structure, line numbers %>
        <div style="font-size:14px;font-weight:600;margin-bottom:16px;color:var(--danger);"><%- typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></div>

        <% if (typeof stack !== 'undefined' && stack) { %>
        <div style="margin-top:16px;">
          <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Stack Trace</div>
          <%# VULNERABILITY: Full stack trace exposed — reveals internal file paths, line numbers, dependencies %>
          <pre style="font-size:11px;max-height:320px;overflow-y:auto;white-space:pre-wrap;word-break:break-all;"><%- stack %></pre>
        </div>
        <% } %>

        <div style="margin-top:20px;display:flex;gap:10px;">
          <a href="javascript:history.back()" class="btn btn-secondary btn-sm">← Go Back</a>
          <a href="/dashboard" class="btn btn-primary btn-sm">Dashboard</a>
        </div>

        <p style="margin-top:16px;font-size:11px;color:var(--text-light);">
          Request ID: <%= Math.random().toString(36).slice(2).toUpperCase() %> ·
          Syntex v2.4.1 · Node.js ·
          <a href="/contact" style="color:var(--text-light);">Report this issue</a>
        </p>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
