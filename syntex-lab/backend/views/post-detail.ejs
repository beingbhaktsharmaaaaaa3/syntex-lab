<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Knowledge Base</span>
      <div class="header-right">
        <a href="/blog" class="btn btn-secondary btn-sm">← All Articles</a>
        <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
      </div>
    </div>
    <div class="page-body">
      <div class="breadcrumb"><a href="/dashboard">Dashboard</a><span>›</span><a href="/blog">Knowledge Base</a><span>›</span><span><%= post.category %></span></div>

      <div style="display:flex;gap:24px;align-items:start;">
        <article style="flex:1;min-width:0;">
          <div class="card mb-4">
            <div class="card-body" style="padding:32px;">
              <div class="post-cat" style="margin-bottom:12px;"><%= post.category %></div>
              <h1 style="font-size:24px;font-weight:800;line-height:1.3;margin-bottom:16px;"><%= post.title %></h1>
              <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--border);">
                <div style="width:36px;height:36px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;">
                  <%= (post.first_name||post.author).charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div style="font-size:13px;font-weight:600;"><%= post.first_name ? post.first_name+' '+post.last_name : post.author %></div>
                  <div style="font-size:11px;color:var(--text-muted);"><%= new Date(post.created_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %> · <%= post.views %> views</div>
                </div>
                <% if (post.tags) { %>
                <div style="margin-left:auto;display:flex;gap:4px;flex-wrap:wrap;">
                  <% post.tags.split(',').forEach(t => { %><span style="background:var(--page-bg);border:1px solid var(--border);padding:2px 8px;border-radius:12px;font-size:11px;color:var(--text-muted);"><%= t.trim() %></span><% }) %>
                </div>
                <% } %>
              </div>
              <div style="font-size:14px;line-height:1.8;color:var(--text);"><%- post.content %></div>
            </div>
          </div>

          <!-- Comments Section -->
          <div class="card" id="comments">
            <div class="card-header"><h3>Comments (<%= comments.length %>)</h3></div>
            <div class="card-body" style="padding:0 24px;">
              <% if (comments.length === 0) { %>
                <p class="text-muted" style="padding:20px 0;font-size:13px;">No comments yet. Be the first to comment.</p>
              <% } else { %>
                <% comments.forEach(c => { %>
                <div class="comment">
                  <div class="comment-meta">
                    <div style="width:28px;height:28px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;">
                      <%= (c.author_name||'U').charAt(0).toUpperCase() %>
                    </div>
                    <span class="comment-author"><%= c.author_name %></span>
                    <span class="comment-date"><%= new Date(c.created_at).toLocaleDateString() %></span>
                  </div>
                  <%# VULNERABILITY: Stored XSS — comment.content rendered as raw HTML %>
                  <%# Payload: <script>console.log('FLAG{stored_xss_blog_comments_executed_e7f8g9h0}'); alert(document.cookie)</script> %>
                  <%# The flag prints in browser console when XSS fires — paste it in your report %>
                  <div class="comment-body"><%- c.content %></div>
                </div>
                <% }) %>
              <% } %>
            </div>
            <div class="card-footer">
              <p style="font-size:12px;font-weight:600;margin-bottom:10px;">Leave a comment</p>
              <%# VULNERABILITY: No CSRF token on this form %>
              <form action="/blog/<%= post.id %>/comment" method="POST">
                <div class="form-group">
                  <textarea name="content" rows="3" placeholder="Share your thoughts…" required style="font-size:13px;"></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Post Comment</button>
              </form>
            </div>
          </div>
        </article>

        <aside style="width:240px;flex-shrink:0;">
          <div class="card">
            <div class="card-header"><h3>About the Author</h3></div>
            <div class="card-body" style="text-align:center;">
              <div style="width:48px;height:48px;border-radius:50%;background:var(--primary);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#fff;">
                <%= (post.first_name||post.author).charAt(0).toUpperCase() %>
              </div>
              <div style="font-size:14px;font-weight:600;"><%= post.first_name ? post.first_name+' '+post.last_name : post.author %></div>
              <a href="/profile/<%= post.author_id %>" class="btn btn-secondary btn-sm" style="margin-top:10px;">View Profile</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
