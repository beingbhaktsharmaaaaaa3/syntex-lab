<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Dashboard</span>
      <div class="header-right">
        <form action="/search" method="GET" style="display:flex;">
          <div class="search-bar">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" id="header-search" name="q" placeholder="Search products, posts…">
          </div>
        </form>
        <div id="search-preview" style="font-size:12px;color:var(--text-muted);"></div>
        <a href="/tickets/new" class="header-icon-btn" title="New ticket">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          <% if (stats && parseInt(stats.unread_notifs) > 0) { %><span class="badge-dot"></span><% } %>
        </a>
        <a href="/profile/<%= user.id %>" class="header-user">
          <div class="header-avatar"><%= ((user.first_name || user.username).charAt(0)).toUpperCase() %></div>
          <div><div class="header-user-name"><%= user.first_name || user.username %></div><div class="header-user-role"><%= user.role %></div></div>
        </a>
      </div>
    </div>

    <div class="page-body">
      <div id="flash-message" style="margin-bottom:12px;"></div>
      <div id="flash-error" style="margin-bottom:12px;"></div>

      <div class="page-header">
        <h1>Welcome back, <%= user.first_name || user.username %>.</h1>
        <p>Here's what's happening with your account today.</p>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total Orders</div>
          <div class="stat-value"><%= stats ? stats.total_orders : 0 %></div>
          <div class="stat-meta">Lifetime licenses &amp; subscriptions</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active Spend</div>
          <div class="stat-value">$<%= stats ? parseFloat(stats.total_spent).toFixed(2) : '0.00' %></div>
          <div class="stat-meta">Monthly recurring</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Open Tickets</div>
          <div class="stat-value"><%= stats ? stats.open_tickets : 0 %></div>
          <div class="stat-meta">Awaiting support response</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Notifications</div>
          <div class="stat-value"><%= stats ? stats.unread_notifs : 0 %></div>
          <div class="stat-meta">Unread alerts</div>
        </div>
      </div>

      <div class="grid-2" style="margin-bottom:24px;">
        <div class="card">
          <div class="card-header">
            <h3>Recent Orders</h3>
            <a href="/orders" class="btn btn-secondary btn-sm">View all</a>
          </div>
          <div class="table-wrapper">
            <table>
              <thead><tr><th>Invoice</th><th>Product</th><th>Amount</th><th>Status</th></tr></thead>
              <tbody>
                <% if (recentOrders && recentOrders.length > 0) { %>
                  <% recentOrders.forEach(o => { %>
                  <tr>
                    <td><a href="/orders/<%= o.id %>" style="color:var(--accent);text-decoration:none;font-weight:600;"><%= o.invoice_number %></a></td>
                    <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= o.product_name %></td>
                    <td>$<%= parseFloat(o.total_price).toFixed(2) %></td>
                    <td><span class="badge badge-<%= o.status === 'active' ? 'success' : o.status === 'pending' ? 'warning' : o.status === 'cancelled' ? 'danger' : 'gray' %>"><%= o.status %></span></td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4" class="text-center text-muted" style="padding:24px;">No orders yet. <a href="/products">Browse products →</a></td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h3>Support Tickets</h3>
            <a href="/tickets" class="btn btn-secondary btn-sm">View all</a>
          </div>
          <div class="table-wrapper">
            <table>
              <thead><tr><th>Subject</th><th>Priority</th><th>Status</th></tr></thead>
              <tbody>
                <% if (recentTickets && recentTickets.length > 0) { %>
                  <% recentTickets.forEach(t => { %>
                  <tr>
                    <td><a href="/tickets/<%= t.id %>" style="color:var(--accent);text-decoration:none;"><%= t.subject.length > 40 ? t.subject.slice(0,40)+'…' : t.subject %></a></td>
                    <td><span class="badge badge-<%= t.priority === 'critical' ? 'danger' : t.priority === 'high' ? 'warning' : 'gray' %>"><%= t.priority %></span></td>
                    <td><span class="badge badge-<%= t.status === 'open' ? 'info' : t.status === 'resolved' ? 'success' : 'gray' %>"><%= t.status %></span></td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="3" class="text-center text-muted" style="padding:24px;">No open tickets.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="grid-2">
        <div class="card">
          <div class="card-header"><h3>Notifications</h3></div>
          <div class="card-body" style="padding:0 20px;">
            <ul class="notif-list">
              <% if (notifications && notifications.length > 0) { %>
                <% notifications.forEach(n => { %>
                <li class="notif-item">
                  <div class="notif-dot <%= n.is_read ? 'read' : '' %>"></div>
                  <div>
                    <div class="notif-title"><%= n.title %></div>
                    <div class="notif-msg"><%= n.message %></div>
                    <div class="notif-time"><%= new Date(n.created_at).toLocaleDateString() %></div>
                  </div>
                </li>
                <% }) %>
              <% } else { %>
                <li class="notif-item"><div class="notif-msg" style="padding:16px 0;">No new notifications.</div></li>
              <% } %>
            </ul>
          </div>
        </div>

        <div class="card">
          <div class="card-header"><h3>Latest from Knowledge Base</h3><a href="/blog" class="btn btn-secondary btn-sm">View all</a></div>
          <div class="card-body" style="padding:0;">
            <% if (recentPosts && recentPosts.length > 0) { %>
              <% recentPosts.forEach(p => { %>
              <div style="padding:16px 20px;border-bottom:1px solid var(--border-light);">
                <div class="post-cat"><%= p.category %></div>
                <a href="/blog/<%= p.slug %>" style="font-size:13px;font-weight:600;color:var(--text);text-decoration:none;"><%= p.title %></a>
                <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">By <%= p.author %> · <%= new Date(p.created_at).toLocaleDateString() %></div>
              </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
