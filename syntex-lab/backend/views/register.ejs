<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-side">
    <h1>Join Syntex Solutions</h1>
    <p>Create your enterprise account and get access to all Syntex modules with a 30-day free trial.</p>
    <div class="auth-features">
      <div class="auth-feature">
        <div class="auth-feature-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
        <div class="auth-feature-text"><strong>30-Day Free Trial</strong><span>Full access to all modules, no credit card</span></div>
      </div>
      <div class="auth-feature">
        <div class="auth-feature-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
        <div class="auth-feature-text"><strong>Dedicated Support</strong><span>Onboarding specialist assigned to your account</span></div>
      </div>
    </div>
  </div>
  <div class="auth-form-side">
    <div class="auth-form-box">
      <h2>Create your account</h2>
      <p>Get started with Syntex Solutions in minutes.</p>
      <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <!-- VULNERABILITY: No CSRF token -->
      <form action="/register" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label>First Name</label>
            <input type="text" name="first_name" placeholder="Jane" required>
          </div>
          <div class="form-group">
            <label>Last Name</label>
            <input type="text" name="last_name" placeholder="Smith" required>
          </div>
        </div>
        <div class="form-group">
          <label>Username<span class="form-required">*</span></label>
          <input type="text" name="username" placeholder="jane.smith" required>
        </div>
        <div class="form-group">
          <label>Work Email<span class="form-required">*</span></label>
          <input type="email" name="email" placeholder="jane@company.com" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Password<span class="form-required">*</span></label>
            <input type="password" name="password" placeholder="Min 4 characters" required>
          </div>
          <div class="form-group">
            <label>Confirm Password</label>
            <input type="password" name="confirm_password" placeholder="Repeat password" required>
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100 btn-lg">Create Account</button>
      </form>
      <div class="auth-footer">Already have an account? <a href="/login">Sign in</a></div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
