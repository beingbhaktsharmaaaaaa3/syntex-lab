<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">Contact Support</span>
      <div class="header-right"><a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a></div>
    </div>
    <div class="page-body">
      <div class="page-header"><h1>Contact Support</h1><p>Send us a message and we'll get back to you within one business day.</p></div>
      <% if (success) { %><div class="alert alert-success alert-auto-dismiss"><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert-danger"><%- error %></div><% } %>
      <div class="grid-2" style="align-items:start;">
        <div class="card"><div class="card-header"><h3>Send a Message</h3></div>
          <div class="card-body">
            <!-- VULNERABILITY: No CSRF token; name/subject used in shell command on server -->
            <form action="/contact" method="POST">
              <div class="form-row">
                <div class="form-group"><label>Full Name<span class="form-required">*</span></label><input type="text" name="name" value="<%= locals.user ? user.first_name+' '+(user.last_name||'') : '' %>" required placeholder="Your full name"></div>
                <div class="form-group"><label>Email<span class="form-required">*</span></label><input type="email" name="email" value="<%= locals.user ? user.email : '' %>" required placeholder="your@email.com"></div>
              </div>
              <div class="form-group"><label>Department</label>
                <select name="department">
                  <option value="sales">Sales</option><option value="support">Technical Support</option>
                  <option value="billing">Billing</option><option value="security">Security</option><option value="other">Other</option>
                </select>
              </div>
              <div class="form-group"><label>Subject<span class="form-required">*</span></label><input type="text" name="subject" required placeholder="Brief description of your inquiry"></div>
              <div class="form-group"><label>Message<span class="form-required">*</span></label><textarea name="message" rows="5" required placeholder="How can we help you?"></textarea></div>
              <button type="submit" class="btn btn-primary">Send Message</button>
            </form>
          </div>
        </div>
        <div>
          <div class="card mb-4"><div class="card-header"><h3>Other Ways to Reach Us</h3></div>
            <div class="card-body" style="font-size:13px;">
              <p style="margin-bottom:12px;"><strong>Email:</strong> support@syntex.local</p>
              <p style="margin-bottom:12px;"><strong>Security:</strong> security@syntex.local</p>
              <p style="margin-bottom:12px;"><strong>Hours:</strong> Monday–Friday, 9am–6pm EST</p>
              <p><strong>Emergency:</strong> +1-800-SYNTEX-1</p>
            </div>
          </div>
          <div class="card"><div class="card-header"><h3>Response Times</h3></div>
            <div class="card-body">
              <table style="font-size:12px;width:100%;">
                <tr><td style="padding:5px 0;">Critical issues</td><td class="text-right fw-bold" style="color:var(--danger);">2 hours</td></tr>
                <tr><td style="padding:5px 0;">High priority</td><td class="text-right fw-bold" style="color:var(--warning);">4 hours</td></tr>
                <tr><td style="padding:5px 0;">Standard</td><td class="text-right">1 business day</td></tr>
                <tr><td style="padding:5px 0;">Feature requests</td><td class="text-right">3–5 business days</td></tr>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
