<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Flag Hunt</span>
      <div class="header-right">
        <a href="/program/submit" class="btn btn-primary btn-sm">+ Submit Report</a>
        <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
      </div>
    </div>
    <div class="page-body">
      <div class="breadcrumb"><a href="/program">Bug Bounty</a><span>›</span><a href="/program/reports">Reports</a><span>›</span><span>Flag Hunt</span></div>

      <!-- Progress Header -->
      <div class="card mb-4" style="background:linear-gradient(135deg,#1B3A6B,#2D5E8E);color:#fff;border:none;">
        <div class="card-body" style="padding:24px;">
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
            <div>
              <h2 style="font-size:20px;font-weight:800;margin-bottom:4px;">🚩 Flag Hunt</h2>
              <p style="opacity:0.75;font-size:13px;">Find hidden flags by exploiting real vulnerabilities. Each flag proves you found the bug.</p>
            </div>
            <div style="text-align:right;">
              <div style="font-size:36px;font-weight:800;"><%= foundSlugs.size %><span style="font-size:18px;opacity:0.6;">/<%= flags.length %></span></div>
              <div style="font-size:12px;opacity:0.7;">flags captured</div>
              <div style="font-size:20px;font-weight:700;color:#FCD34D;margin-top:4px;"><%= totalPoints %> pts</div>
            </div>
          </div>
          <!-- Progress bar -->
          <div style="margin-top:16px;background:rgba(0,0,0,0.3);border-radius:20px;height:8px;overflow:hidden;">
            <div style="height:100%;background:#FCD34D;border-radius:20px;transition:width 0.5s;width:<%= flags.length > 0 ? Math.round(foundSlugs.size/flags.length*100) : 0 %>%;"></div>
          </div>
          <div style="font-size:11px;opacity:0.6;margin-top:6px;"><%= flags.length > 0 ? Math.round(foundSlugs.size/flags.length*100) : 0 %>% complete · <%= maxPoints %> total points available</div>
        </div>
      </div>

      <!-- How it works -->
      <div class="alert alert-info mb-4">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>Exploit vulnerabilities in the lab → find the <code>FLAG{...}</code> string → submit a report with the flag → get instantly verified. <a href="/program/hints" style="color:var(--info);">Need hints?</a></span>
      </div>

      <!-- Flags by category -->
      <%
        const categories = [...new Set(flags.map(f => f.category))].sort();
      %>
      <% categories.forEach(cat => { %>
      <div class="card mb-4">
        <div class="card-header">
          <h3><%= cat %></h3>
          <%
            const catFlags = flags.filter(f => f.category === cat);
            const catFound = catFlags.filter(f => foundSlugs.has(f.slug)).length;
          %>
          <span style="font-size:12px;color:var(--text-muted);"><%= catFound %>/<%= catFlags.length %> found</span>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr><th>Status</th><th>Vulnerability</th><th>Points</th><th>Location Hint</th><th>Found</th><th></th></tr>
            </thead>
            <tbody>
              <% flags.filter(f => f.category === cat).forEach(f => { %>
              <% const isCaptured = foundSlugs.has(f.slug); %>
              <tr style="<%= isCaptured ? 'background:#F0FDF4;' : '' %>">
                <td>
                  <% if (isCaptured) { %>
                    <span style="font-size:18px;" title="Captured!">✅</span>
                  <% } else { %>
                    <span style="font-size:18px;" title="Not found yet">🔒</span>
                  <% } %>
                </td>
                <td>
                  <div style="font-weight:600;font-size:13px;"><%= f.vuln_title %></div>
                  <div style="font-size:11px;color:var(--text-muted);">slug: <code><%= f.slug %></code></div>
                </td>
                <td>
                  <span style="font-weight:700;color:<%= isCaptured ? 'var(--success)' : 'var(--text-muted)' %>;">
                    <%= isCaptured ? '+' : '' %><%= f.points %> pts
                  </span>
                </td>
                <td style="font-size:12px;color:var(--text-muted);max-width:260px;"><%= f.location_hint %></td>
                <td style="font-size:11px;color:var(--text-muted);">
                  <% if (isCaptured && foundMap[f.slug]) { %>
                    <%= new Date(foundMap[f.slug]).toLocaleDateString() %>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td>
                  <% if (!isCaptured) { %>
                    <a href="/program/hints/<%= f.slug %>" class="btn btn-secondary btn-sm">Hints →</a>
                  <% } else { %>
                    <a href="/program/submit" class="btn btn-primary btn-sm">Report →</a>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% }) %>

      <!-- CTA -->
      <div class="card">
        <div class="card-body" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
          <div>
            <div style="font-weight:700;">Found a flag? Submit your report.</div>
            <div style="font-size:12px;color:var(--text-muted);">Include the FLAG{...} string for instant verification.</div>
          </div>
          <div style="display:flex;gap:8px;">
            <a href="/program/submit" class="btn btn-primary">Submit Report →</a>
            <a href="/program/challenges" class="btn btn-secondary">Vuln Chains →</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
