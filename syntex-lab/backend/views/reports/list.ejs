<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">My Reports</span>
      <div class="header-right">
        <a href="/reports/new" class="btn btn-primary btn-sm">+ New Report</a>
        <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
      </div>
    </div>
    <div class="page-body">
      <div class="breadcrumb"><a href="/bug-bounty">Bug Bounty</a><span>›</span><span>My Reports</span></div>

      <!-- Status filter tabs -->
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px;">
        <% const tabs = [
          {key:null,   label:'All',           color:'badge-gray'},
          {key:'new',  label:'New',           color:'badge-info'},
          {key:'needs_more_info', label:'Needs Info', color:'badge-warning'},
          {key:'accepted',        label:'Accepted',   color:'badge-success'},
          {key:'duplicate',       label:'Duplicate',  color:'badge-gray'},
          {key:'informative',     label:'Informative',color:'badge-gray'},
          {key:'not_applicable',  label:'N/A',         color:'badge-danger'},
          {key:'resolved',        label:'Resolved',    color:'badge-success'},
        ]; %>
        <% tabs.forEach(t => { %>
        <a href="/reports<%= t.key ? '?status='+t.key : '' %>"
           style="padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;
                  background:<%= filterStatus===t.key ? 'var(--primary)':'var(--card-bg)' %>;
                  color:<%= filterStatus===t.key ? '#fff':'var(--text-muted)' %>;
                  border:1px solid <%= filterStatus===t.key ? 'var(--primary)':'var(--border)' %>;">
          <%= t.label %>
          <% if (statusMap[t.key] || (!t.key && reports.length)) { %>
            <span style="opacity:0.7;">(<%= t.key ? (statusMap[t.key]||0) : reports.length %>)</span>
          <% } %>
        </a>
        <% }) %>
      </div>

      <% if (reports.length === 0) { %>
        <div class="empty-state">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          <h3>No reports yet</h3>
          <p>Start hunting and <a href="/reports/new" style="color:var(--accent);">submit your first report</a>.</p>
        </div>
      <% } else { %>
      <div class="card">
        <div class="table-wrapper">
          <table>
            <thead><tr><th>#</th><th>Title</th><th>Type</th><th>Severity</th><th>Status</th><th>Bounty</th><th>Submitted</th></tr></thead>
            <tbody>
              <% reports.forEach(r => { %>
              <% const sevColors = {critical:'danger',high:'warning',medium:'info',low:'success',info:'gray'}; %>
              <% const statusColors = {new:'info',needs_more_info:'warning',accepted:'success',duplicate:'gray',informative:'gray',not_applicable:'danger',resolved:'success'}; %>
              <tr>
                <td style="color:var(--text-muted);font-size:12px;">#<%= r.id %></td>
                <td style="max-width:280px;">
                  <a href="/reports/<%= r.id %>" style="color:var(--text);text-decoration:none;font-weight:600;font-size:13px;">
                    <%= r.title.length > 65 ? r.title.slice(0,65)+'…' : r.title %>
                  </a>
                </td>
                <td><span class="badge badge-gray" style="font-size:10px;"><%= r.vuln_type.replace(/_/g,' ') %></span></td>
                <td><span class="badge badge-<%= sevColors[r.severity]||'gray' %>"><%= r.severity %></span></td>
                <td>
                  <span class="badge badge-<%= statusColors[r.status]||'gray' %>" style="white-space:nowrap;">
                    <%= ({new:'🆕 New',needs_more_info:'ℹ️ Needs Info',accepted:'✅ Accepted',duplicate:'🔄 Duplicate',informative:'ℹ️ Informative',not_applicable:'❌ N/A',resolved:'✔️ Resolved'})[r.status] || r.status %>
                  </span>
                </td>
                <td style="font-weight:700;color:<%= r.bounty_amount > 0 ? 'var(--success)' : 'var(--text-muted)' %>;">
                  <%= r.bounty_amount > 0 ? '$'+parseFloat(r.bounty_amount).toLocaleString() : '—' %>
                </td>
                <td style="font-size:12px;color:var(--text-muted);white-space:nowrap;"><%= new Date(r.created_at).toLocaleDateString() %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="card-footer" style="font-size:12px;color:var(--text-muted);">
          <%= reports.length %> report<%= reports.length!==1?'s':'' %> · <a href="/bug-bounty/scope" style="color:var(--accent);">Program scope</a> · <a href="/hints" style="color:var(--accent);">Need hints?</a>
        </div>
      </div>
      <% } %>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
