<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Submit Bug Report</span>
      <div class="header-right">
        <a href="/program/flags" class="btn btn-secondary btn-sm">🚩 Flag Hunt</a>
        <a href="/program/reports" class="btn btn-secondary btn-sm">My Reports</a>
        <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
      </div>
    </div>

    <div class="page-body">
      <div class="breadcrumb"><a href="/program">Bug Bounty</a><span>›</span><a href="/program/reports">Reports</a><span>›</span><span>New</span></div>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

      <div style="display:flex;gap:24px;align-items:start;">
        <div style="flex:1;min-width:0;">
          <div class="card">
            <div class="card-header"><h3>Bug Report</h3><span style="font-size:12px;color:var(--text-muted);">Fields marked * are required</span></div>
            <div class="card-body">
              <form action="/reports" method="POST">

                <!-- Flag Verification Box (highlighted) -->
                <div style="background:linear-gradient(135deg,#EFF6FF,#F0FDF4);border:2px solid #3B82F6;border-radius:var(--radius);padding:18px;margin-bottom:24px;">
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                    <span style="font-size:18px;">🚩</span>
                    <div>
                      <div style="font-weight:700;font-size:14px;">Flag-Based Verification (Optional but recommended)</div>
                      <div style="font-size:12px;color:var(--text-muted);">If you found a FLAG{...} string while exploiting, paste it here for instant auto-verification. Your report gets marked ✅ Verified immediately — no manual review needed.</div>
                    </div>
                  </div>
                  <div class="form-row" style="margin-bottom:0;">
                    <div class="form-group" style="margin-bottom:0;">
                      <label>Vulnerability (for flag matching)</label>
                      <select name="flag_slug" id="flag_slug">
                        <option value="">— Select the vulnerability you exploited —</option>
                        <% const byCategory = {}; %>
                        <% availableFlags.forEach(f => { if(!byCategory[f.category]) byCategory[f.category]=[]; byCategory[f.category].push(f); }); %>
                        <% Object.entries(byCategory).forEach(([cat, fs]) => { %>
                        <optgroup label="<%= cat %>">
                          <% fs.forEach(f => { %>
                          <option value="<%= f.slug %>"><%= f.vuln_title %> (+<%= f.points %> pts)</option>
                          <% }) %>
                        </optgroup>
                        <% }) %>
                      </select>
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                      <label>Flag Value Found</label>
                      <input type="text" name="flag_submitted" id="flag_submitted"
                             placeholder="FLAG{paste_what_you_found_here}"
                             style="font-family:monospace;font-size:12px;">
                      <div class="form-hint">Copy the exact FLAG{...} string from where you found it.</div>
                    </div>
                  </div>
                </div>

                <div class="form-group">
                  <label>Report Title <span class="form-required">*</span></label>
                  <input type="text" name="title" required
                         placeholder='e.g. "SQL Injection in /login allows authentication bypass"'>
                  <div class="form-hint">Format: [Vuln Type] in [Location] allows [Impact]</div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label>Vulnerability Type <span class="form-required">*</span></label>
                    <select name="vuln_type" required>
                      <option value="">— Select —</option>
                      <optgroup label="Injection">
                        <option value="sqli">SQL Injection</option>
                        <option value="cmd_injection">Command Injection</option>
                        <option value="lfi">LFI / Path Traversal</option>
                        <option value="ssrf">SSRF</option>
                      </optgroup>
                      <optgroup label="XSS">
                        <option value="xss_reflected">XSS — Reflected</option>
                        <option value="xss_stored">XSS — Stored</option>
                        <option value="xss_dom">XSS — DOM</option>
                      </optgroup>
                      <optgroup label="Access Control">
                        <option value="idor">IDOR</option>
                        <option value="broken_access">Broken Access Control</option>
                        <option value="auth_bypass">Auth Bypass</option>
                        <option value="csrf">CSRF</option>
                      </optgroup>
                      <optgroup label="Auth / Crypto">
                        <option value="jwt">JWT Vulnerability</option>
                        <option value="weak_crypto">Weak Cryptography</option>
                        <option value="rate_limit">Rate Limit Bypass</option>
                      </optgroup>
                      <optgroup label="Other">
                        <option value="cors">CORS Misconfiguration</option>
                        <option value="open_redirect">Open Redirect</option>
                        <option value="file_upload">File Upload Bypass</option>
                        <option value="business_logic">Business Logic</option>
                        <option value="exposure">Exposed Secrets / Files</option>
                        <option value="info_disclosure">Information Disclosure</option>
                        <option value="other">Other</option>
                      </optgroup>
                    </select>
                  </div>
                  <div class="form-group">
                    <label>Severity <span class="form-required">*</span></label>
                    <select name="severity" required>
                      <option value="">— Select —</option>
                      <option value="critical">🔴 Critical (P1) — CVSS 9.0–10.0</option>
                      <option value="high">🟠 High (P2) — CVSS 7.0–8.9</option>
                      <option value="medium">🟡 Medium (P3) — CVSS 4.0–6.9</option>
                      <option value="low">🟢 Low (P4) — CVSS 0.1–3.9</option>
                      <option value="info">⚪ Informative (P5)</option>
                    </select>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label>CVSS Score</label>
                    <input type="number" name="cvss_score" min="0" max="10" step="0.1" placeholder="e.g. 8.5">
                  </div>
                  <div class="form-group">
                    <label>Affected URL / Endpoint <span class="form-required">*</span></label>
                    <input type="text" name="affected_url" required placeholder="e.g. POST /login">
                  </div>
                </div>

                <div class="form-group">
                  <label>Steps to Reproduce <span class="form-required">*</span></label>
                  <textarea name="steps" rows="6" required
                    placeholder="1. Navigate to /login&#10;2. Enter username: admin'--&#10;3. Enter any password&#10;4. Click Login&#10;5. Observe: authenticated as admin without valid credentials"></textarea>
                  <div class="form-hint">Numbered steps. Must be reproducible in under 5 minutes.</div>
                </div>

                <div class="form-group">
                  <label>Impact <span class="form-required">*</span></label>
                  <textarea name="impact" rows="4" required
                    placeholder="What can an attacker actually achieve? What data is exposed? How many users affected?"></textarea>
                </div>

                <div class="form-group">
                  <label>Proof of Concept</label>
                  <textarea name="proof_of_concept" rows="5"
                    placeholder="Paste your payload, curl command, Burp request, or describe your PoC."></textarea>
                </div>

                <div class="form-group">
                  <label>Suggested Fix</label>
                  <textarea name="suggested_fix" rows="3"
                    placeholder="What code change or configuration fix would resolve this?"></textarea>
                </div>

                <div style="display:flex;gap:10px;padding-top:8px;">
                  <button type="submit" class="btn btn-primary btn-lg">Submit Report</button>
                  <a href="/program/reports" class="btn btn-secondary btn-lg">Cancel</a>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside style="width:240px;flex-shrink:0;">
          <div class="card mb-4" style="border-color:#3B82F6;">
            <div class="card-header" style="background:#EFF6FF;"><h3 style="color:#1D4ED8;">How Flag Verification Works</h3></div>
            <div class="card-body" style="font-size:12px;line-height:1.8;">
              <div style="display:flex;flex-direction:column;gap:10px;">
                <div><span style="font-weight:700;color:var(--primary);">Step 1</span><br>Exploit a vulnerability in the lab.</div>
                <div><span style="font-weight:700;color:var(--primary);">Step 2</span><br>Find the hidden <code>FLAG{...}</code> string at the proof point.</div>
                <div><span style="font-weight:700;color:var(--primary);">Step 3</span><br>Submit your report and paste the flag above.</div>
                <div><span style="font-weight:700;color:var(--success);">✅ Result</span><br>Your report is instantly marked <strong>Verified</strong> — no waiting for manual review.</div>
              </div>
            </div>
          </div>

          <div class="card mb-4">
            <div class="card-header"><h3>Your Flag Progress</h3></div>
            <div class="card-body" style="text-align:center;padding:16px;">
              <a href="/program/flags" class="btn btn-secondary btn-sm w-100">🚩 View Flag Hunt →</a>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><h3>Need Hints?</h3></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
              <a href="/program/hints" class="btn btn-secondary btn-sm">Browse Hints</a>
              <a href="/program/challenges" class="btn btn-secondary btn-sm">Practice Chains</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
