<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Report #<%= report.id %></span>
      <div class="header-right">
        <a href="/program/flags" class="btn btn-secondary btn-sm">🚩 Flags</a>
        <a href="/program/reports" class="btn btn-secondary btn-sm">← My Reports</a>
        <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
      </div>
    </div>
    <div class="page-body">
      <div class="breadcrumb"><a href="/program">Bug Bounty</a><span>›</span><a href="/program/reports">Reports</a><span>›</span><span>#<%= report.id %></span></div>

      <%
        const sevColors  = {critical:'danger',high:'warning',medium:'info',low:'success',info:'gray'};
        const statColors = {new:'info',needs_more_info:'warning',accepted:'success',duplicate:'gray',informative:'gray',not_applicable:'danger',resolved:'success'};
        const statLabels = {new:'🆕 New',needs_more_info:'ℹ️ Needs More Info',accepted:'✅ Accepted',duplicate:'🔄 Duplicate',informative:'ℹ️ Informative',not_applicable:'❌ N/A',resolved:'✔️ Resolved'};
      %>

      <!-- Auto-verified celebration banner -->
      <% if (justVerified) { %>
      <div style="background:linear-gradient(135deg,#15803D,#16A34A);color:#fff;border-radius:var(--radius);padding:20px 24px;margin-bottom:20px;display:flex;align-items:center;gap:16px;">
        <span style="font-size:32px;">🎉</span>
        <div>
          <div style="font-size:16px;font-weight:800;">Flag Verified! Report Auto-Accepted</div>
          <div style="font-size:13px;opacity:0.85;margin-top:2px;">Your flag was correct. Report marked ✅ Accepted instantly. <%= report.flag_points ? '+'+report.flag_points+' pts' : '' %></div>
        </div>
      </div>
      <% } %>

      <div style="display:flex;gap:24px;align-items:start;">
        <!-- Main report -->
        <div style="flex:1;min-width:0;">

          <!-- Flag verification status card -->
          <% if (report.flag_slug) { %>
          <div class="card mb-4" style="border-color:<%= report.flag_verified ? 'var(--success)' : 'var(--warning)' %>;">
            <div class="card-header" style="background:<%= report.flag_verified ? 'var(--success-bg)' : 'var(--warning-bg)' %>;">
              <div style="display:flex;align-items:center;gap:10px;">
                <span style="font-size:20px;"><%= report.flag_verified ? '✅' : '⚠️' %></span>
                <div>
                  <div style="font-weight:700;font-size:14px;color:<%= report.flag_verified ? 'var(--success)' : 'var(--warning)' %>;">
                    <%= report.flag_verified ? 'Flag Verified — Vulnerability Confirmed' : 'Flag Submitted — Verification Failed' %>
                  </div>
                  <div style="font-size:12px;color:var(--text-muted);">
                    <% if (report.flag_verified) { %>
                      Vulnerability: <strong><%= report.flag_title || report.flag_slug %></strong>
                      <% if (report.flag_points) { %> · <strong style="color:var(--success);">+<%= report.flag_points %> points</strong><% } %>
                      <% if (report.verified_at) { %> · Verified <%= new Date(report.verified_at).toLocaleString() %><% } %>
                    <% } else { %>
                      Flag submitted for <strong><%= report.flag_slug %></strong> but did not match the expected value. Try re-exploiting the vulnerability and check you copied the flag exactly.
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
            <% if (report.flag_submitted && !report.flag_verified) { %>
            <div class="card-body" style="padding:12px 20px;">
              <div style="font-size:12px;color:var(--text-muted);">Submitted: <code style="background:#F3F4F6;padding:2px 6px;border-radius:3px;"><%= report.flag_submitted %></code></div>
            </div>
            <% } %>
          </div>
          <% } else if (!report.flag_verified) { %>
          <div class="card mb-4" style="border-color:#D1D9E6;border-style:dashed;">
            <div class="card-body" style="display:flex;align-items:center;gap:16px;padding:16px 20px;">
              <span style="font-size:24px;">🚩</span>
              <div style="flex:1;">
                <div style="font-weight:600;font-size:13px;">No flag submitted — awaiting manual triage</div>
                <div style="font-size:12px;color:var(--text-muted);">If you can find the FLAG{...} string proving this vulnerability exists, it will be auto-verified instantly.</div>
              </div>
              <a href="/program/flags" class="btn btn-secondary btn-sm">Flag Hunt →</a>
            </div>
          </div>
          <% } %>

          <!-- Report content -->
          <div class="card mb-4">
            <div class="card-header" style="flex-wrap:wrap;gap:8px;">
              <div>
                <h2 style="font-size:16px;font-weight:700;"><%= report.title %></h2>
                <div style="display:flex;gap:8px;margin-top:6px;flex-wrap:wrap;">
                  <span class="badge badge-<%= sevColors[report.severity]||'gray' %>"><%= report.severity %></span>
                  <span class="badge badge-<%= statColors[report.status]||'gray' %>"><%= statLabels[report.status]||report.status %></span>
                  <span class="badge badge-gray"><%= report.vuln_type.replace(/_/g,' ') %></span>
                  <% if (report.flag_verified) { %><span class="badge badge-success">🚩 Flag Verified</span><% } %>
                  <% if (report.cvss_score) { %><span class="badge badge-gray">CVSS <%= report.cvss_score %></span><% } %>
                </div>
              </div>
              <% if (report.bounty_amount > 0) { %>
              <div style="text-align:right;">
                <div style="font-size:22px;font-weight:800;color:var(--success);">$<%= parseFloat(report.bounty_amount).toLocaleString() %></div>
                <div style="font-size:11px;color:var(--text-muted);">Bounty awarded</div>
              </div>
              <% } %>
            </div>
            <div class="card-body">
              <div style="font-size:12px;color:var(--text-muted);margin-bottom:20px;display:flex;gap:16px;flex-wrap:wrap;">
                <span>By <strong><%= report.reporter %></strong></span>
                <span>Submitted <%= new Date(report.created_at).toLocaleString() %></span>
                <% if (report.affected_url) { %><span>Endpoint: <code style="font-size:11px;"><%= report.affected_url %></code></span><% } %>
              </div>

              <% const sec = (t, body) => { %>
              <div style="margin-bottom:20px;">
                <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;"><%= t %></div>
                <div style="font-size:13px;line-height:1.8;white-space:pre-wrap;background:var(--page-bg);padding:12px;border-radius:var(--radius);border:1px solid var(--border-light);"><%= body %></div>
              </div>
              <% } %>

              <% if (report.steps)            { %><%- sec('Steps to Reproduce', report.steps) %><% } %>
              <% if (report.impact)           { %><%- sec('Impact', report.impact) %><% } %>
              <% if (report.proof_of_concept) { %>
              <div style="margin-bottom:20px;">
                <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Proof of Concept</div>
                <pre style="font-size:12px;max-height:260px;overflow-y:auto;"><%= report.proof_of_concept %></pre>
              </div>
              <% } %>
              <% if (report.suggested_fix) { %><%- sec('Suggested Fix', report.suggested_fix) %><% } %>
            </div>
          </div>

          <% if (report.triage_notes) { %>
          <div class="card mb-4" style="border-color:#BBF7D0;">
            <div class="card-header" style="background:#F0FDF4;">
              <h3>Triage Response</h3>
              <% if (report.triager) { %><span style="font-size:12px;color:var(--text-muted);">by <%= report.triager %></span><% } %>
            </div>
            <div class="card-body"><p style="font-size:13px;line-height:1.7;white-space:pre-wrap;"><%= report.triage_notes %></p></div>
          </div>
          <% } %>
        </div>

        <!-- Sidebar -->
        <aside style="width:280px;flex-shrink:0;">
          <!-- Admin triage panel -->
          <% if (isStaff) { %>
          <div class="card mb-4" style="border-color:var(--warning);">
            <div class="card-header" style="background:#FFFBEB;"><h3>Triage Panel</h3><span class="badge badge-warning">Staff</span></div>
            <div class="card-body">
              <form action="/reports/<%= report.id %>/triage" method="POST">
                <div class="form-group">
                  <label>Status</label>
                  <select name="status" required>
                    <% ['new','needs_more_info','accepted','duplicate','informative','not_applicable','resolved'].forEach(s => { %>
                    <option value="<%= s %>" <%= report.status===s?'selected':'' %>>
                      <%= ({new:'🆕 New',needs_more_info:'ℹ️ Needs Info',accepted:'✅ Accepted',duplicate:'🔄 Duplicate',informative:'ℹ️ Informative',not_applicable:'❌ N/A',resolved:'✔️ Resolved'})[s] %>
                    </option>
                    <% }) %>
                  </select>
                </div>
                <div class="form-group">
                  <label>Bounty ($)</label>
                  <input type="number" name="bounty_amount" min="0" step="50" value="<%= report.bounty_amount||0 %>">
                </div>
                <div class="form-group">
                  <label>Duplicate of #</label>
                  <input type="number" name="duplicate_of" min="1" value="<%= report.duplicate_of||'' %>" placeholder="Leave blank if not duplicate">
                </div>
                <div class="form-group">
                  <label>Triage Notes</label>
                  <textarea name="triage_notes" rows="4" placeholder="Response to researcher…"><%= report.triage_notes||'' %></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100">Update</button>
              </form>
            </div>
          </div>
          <% } %>

          <div class="card mb-4">
            <div class="card-header"><h3>Report Info</h3></div>
            <div class="card-body">
              <table style="font-size:12px;width:100%;">
                <tr><td style="padding:4px 0;color:var(--text-muted);">Report ID</td><td>#<%= report.id %></td></tr>
                <tr><td style="padding:4px 0;color:var(--text-muted);">Reporter</td><td><%= report.reporter %></td></tr>
                <tr><td style="padding:4px 0;color:var(--text-muted);">Severity</td><td><span class="badge badge-<%= sevColors[report.severity]||'gray' %>"><%= report.severity %></span></td></tr>
                <tr><td style="padding:4px 0;color:var(--text-muted);">Status</td><td><span class="badge badge-<%= statColors[report.status]||'gray' %>"><%= statLabels[report.status]||report.status %></span></td></tr>
                <tr><td style="padding:4px 0;color:var(--text-muted);">Verified</td>
                  <td><% if(report.flag_verified){%><span style="color:var(--success);font-weight:700;">✅ Yes</span><%}else{%><span style="color:var(--text-muted);">⏳ Pending</span><%}%></td></tr>
                <tr><td style="padding:4px 0;color:var(--text-muted);">Submitted</td><td><%= new Date(report.created_at).toLocaleDateString() %></td></tr>
                <% if(report.bounty_amount>0){%>
                <tr><td style="padding:4px 0;color:var(--text-muted);">Bounty</td><td style="font-weight:700;color:var(--success);">$<%= parseFloat(report.bounty_amount).toLocaleString() %></td></tr>
                <%}%>
              </table>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><h3>Next Steps</h3></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:8px;">
              <a href="/program/submit" class="btn btn-primary btn-sm">Submit Another Report</a>
              <a href="/program/flags" class="btn btn-secondary btn-sm">🚩 Flag Hunt</a>
              <a href="/program/hints" class="btn btn-secondary btn-sm">Browse Hints</a>
              <a href="/program/challenges" class="btn btn-secondary btn-sm">Vuln Chains</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
