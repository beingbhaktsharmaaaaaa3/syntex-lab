<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>404 — Page Not Found · Syntex Solutions</title>
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--page-bg);">
  <div style="text-align:center;max-width:480px;padding:48px 24px;">
    <div style="font-size:96px;font-weight:800;color:var(--border);line-height:1;margin-bottom:16px;">404</div>
    <h1 style="font-size:22px;font-weight:700;margin-bottom:8px;">Page Not Found</h1>
    <p style="color:var(--text-muted);font-size:14px;margin-bottom:32px;">The page you requested could not be found on this server. If you believe this is an error, please contact support.</p>
    <!-- VULNERABILITY: Path reflected without encoding — can leak internal path info -->
    <p style="font-size:12px;color:var(--text-light);font-family:monospace;background:var(--border-light);padding:8px 12px;border-radius:var(--radius);margin-bottom:24px;">Requested path: <%= typeof path !== 'undefined' ? path : '' %></p>
    <div style="display:flex;gap:10px;justify-content:center;">
      <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
      <a href="/" class="btn btn-secondary">Home</a>
    </div>
    <p style="margin-top:32px;font-size:11px;color:var(--text-light);">Syntex Solutions v2.4.1 · <a href="/contact" style="color:var(--text-light);">Contact Support</a></p>
  </div>
</div>
<%- include('partials/footer') %>
