<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> — Syntex Solutions</title>
<link rel="stylesheet" href="/css/style.css"></head>
<body style="background:var(--page-bg);display:flex;align-items:center;justify-content:center;min-height:100vh;">
<div style="width:100%;max-width:440px;padding:24px;">
  <div class="card">
    <div style="padding:28px 28px 0;text-align:center;">
      <div style="width:56px;height:56px;background:var(--primary);border-radius:12px;margin:0 auto 14px;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:800;color:#fff;">S</div>
      <h2 style="font-size:17px;font-weight:700;margin-bottom:4px;"><%= app.name %> wants access</h2>
      <p style="font-size:13px;color:var(--text-muted);">This application is requesting permission to access your Syntex account.</p>
    </div>
    <div class="card-body">
      <!-- VULNERABILITY: No state parameter displayed/verified — CSRF in OAuth flow -->
      <% if (!state) { %>
      <div class="alert alert-warning" style="font-size:12px;">⚠️ No state parameter present — this authorization request may be forged.</div>
      <% } %>
      <div style="background:var(--page-bg);border:1px solid var(--border);border-radius:var(--radius);padding:14px;margin-bottom:18px;">
        <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Permissions Requested</div>
        <div style="display:flex;flex-direction:column;gap:6px;font-size:13px;">
          <% (scope||'read').split(' ').forEach(s => { %>
          <div style="display:flex;align-items:center;gap:8px;"><span style="color:var(--success);font-weight:700;">✓</span>
          <span><%= ({read:'Read your profile and data',write:'Modify your account data',admin:'Full admin access',email:'Access your email address',profile:'View your profile'})[s] || s %></span></div>
          <% }) %>
        </div>
      </div>
      <form action="/oauth/authorize" method="POST">
        <input type="hidden" name="client_id"    value="<%= client_id %>">
        <input type="hidden" name="redirect_uri" value="<%= redirect_uri %>">
        <input type="hidden" name="scope"        value="<%= scope %>">
        <input type="hidden" name="state"        value="<%= state %>">
        <!-- VULNERABILITY: No CSRF token on this form -->
        <div style="display:flex;gap:10px;">
          <button type="submit" name="action" value="allow"  class="btn btn-primary"    style="flex:1;">Authorize</button>
          <button type="submit" name="action" value="deny"   class="btn btn-secondary"  style="flex:1;">Deny</button>
        </div>
      </form>
      <p style="font-size:11px;color:var(--text-muted);text-align:center;margin-top:12px;">Authorizing as <strong><%= user ? user.username : 'unknown' %></strong>. <a href="/logout" style="color:var(--accent);">Not you?</a></p>
    </div>
  </div>
  <p style="font-size:11px;color:var(--text-muted);text-align:center;margin-top:12px;">Syntex OAuth 2.0 · <a href="/oauth/.well-known/openid-configuration" style="color:var(--text-muted);">OIDC Config</a></p>
</div>
</body></html>
