<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div class="prog-card" style="max-width:500px;margin:60px auto;text-align:center;">
    <div class="prog-card-body" style="padding:48px 32px;">
      <div style="font-size:48px;margin-bottom:16px;">🔒</div>
      <h2 style="font-size:18px;font-weight:700;margin-bottom:8px;"><%= feature.charAt(0).toUpperCase()+feature.slice(1) %> — Hidden in <%= mode.toUpperCase() %> Mode</h2>
      <p style="color:var(--prog-muted);font-size:13px;line-height:1.7;margin-bottom:20px;">In <strong><%= mode %></strong> mode, <%= feature %> are not shown. This simulates a real bug bounty environment where there are no hints or guides.</p>
      <p style="color:var(--prog-muted);font-size:12px;">To enable hints and flags, change <code>LAB_MODE=beginner</code> in <code>docker-compose.yml</code> and restart.</p>
      <div style="margin-top:20px;display:flex;gap:8px;justify-content:center;">
        <a href="/program" class="prog-btn prog-btn-outline">← Program</a>
        <a href="/program/scope" class="prog-btn prog-btn-green">View Scope</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/program-footer') %>
