<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div style="margin-bottom:20px;">
    <div style="font-size:12px;color:var(--prog-muted);margin-bottom:4px;"><a href="/program" style="color:#25855A;text-decoration:none;">Program</a> › Rules</div>
    <h1 style="font-size:22px;font-weight:800;">Rules of Engagement</h1>
    <p style="color:var(--prog-muted);font-size:13px;">Read carefully before testing. Violating these rules may result in your findings being rejected.</p>
  </div>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start;">
    <div>

      <div class="prog-card" style="margin-bottom:20px;">
        <div class="prog-card-header"><h3>Testing Rules</h3></div>
        <div class="prog-card-body" style="font-size:13px;line-height:1.9;">
          <% [
            ['✅ DO',     'Only test assets listed in the in-scope section.'],
            ['✅ DO',     'Test only within the local lab environment (127.0.0.1, localhost).'],
            ['✅ DO',     'Submit one report per unique vulnerability — include exact steps.'],
            ['✅ DO',     'Include a working proof of concept in every report.'],
            ['✅ DO',     'Explain the real-world impact clearly and accurately.'],
            ['✅ DO',     'Report in good faith — avoid unnecessary data access.'],
            ['❌ DO NOT', 'Perform DoS or DDoS attacks of any kind.'],
            ['❌ DO NOT', 'Social engineer other lab users.'],
            ['❌ DO NOT', 'Submit reports based solely on automated scanner output.'],
            ['❌ DO NOT', 'Over-inflate severity — accuracy builds credibility.'],
            ['❌ DO NOT', 'Submit duplicate reports for the same root cause.'],
            ['❌ DO NOT', 'Test against any real external system or service.'],
          ].forEach(([t,r]) => { %>
          <div style="display:flex;gap:12px;margin-bottom:8px;">
            <span style="flex-shrink:0;font-weight:700;color:<%= t.startsWith('✅') ? '#25855A' : '#E53E3E' %>;font-size:12px;min-width:70px;"><%= t %></span>
            <span><%= r %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="prog-card" style="margin-bottom:20px;">
        <div class="prog-card-header"><h3>Valid vs Invalid Reports</h3></div>
        <div class="prog-card-body" style="padding:0;">
          <% [
            {valid:true,  t:'SQL injection bypassing login with authentication as admin',     b:'Clear impact, reproducible, high severity'},
            {valid:true,  t:'Stored XSS in blog comments executes in admin browser',          b:'Chained impact, concrete PoC, realistic scenario'},
            {valid:true,  t:'IDOR on /orders/:id exposes other users PII and license keys',   b:'Specific endpoint, data exposure, real impact'},
            {valid:true,  t:'/.env file exposed with database password and JWT secret',       b:'P1 — immediate credential exposure'},
            {valid:false, t:'Missing Content-Security-Policy header',                         b:'Informative only — no exploitable impact without further chaining'},
            {valid:false, t:'Self-XSS that only affects the logged-in attacker',              b:'No impact to other users — not a valid bug'},
            {valid:false, t:'Username enumeration via different error messages',              b:'Low impact without further exploitation context'},
            {valid:false, t:'Nuclei scanner found potential vulnerability (unverified)',       b:'Scanner output only — manual verification required'},
          ].forEach(r => { %>
          <div style="display:flex;gap:12px;padding:14px 20px;border-bottom:1px solid #F7FAFC;align-items:flex-start;">
            <span style="font-size:18px;flex-shrink:0;margin-top:1px;"><%= r.valid ? '✅' : '❌' %></span>
            <div>
              <div style="font-size:13px;font-weight:600;"><%= r.t %></div>
              <div style="font-size:11px;color:var(--prog-muted);margin-top:2px;"><%= r.b %></div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

    </div>

    <div>
      <div class="prog-card" style="margin-bottom:20px;">
        <div class="prog-card-header"><h3>Response Times SLA</h3></div>
        <table class="prog-table">
          <thead><tr><th>Severity</th><th>First Response</th><th>Resolution</th></tr></thead>
          <tbody>
            <tr><td><span class="prog-badge prog-badge-red">P1</span></td><td>4 hours</td><td>7 days</td></tr>
            <tr><td><span class="prog-badge prog-badge-yellow">P2</span></td><td>24 hours</td><td>30 days</td></tr>
            <tr><td><span class="prog-badge prog-badge-blue">P3</span></td><td>3 days</td><td>60 days</td></tr>
            <tr><td><span class="prog-badge prog-badge-green">P4</span></td><td>7 days</td><td>90 days</td></tr>
            <tr><td><span class="prog-badge prog-badge-gray">P5</span></td><td>14 days</td><td>Backlog</td></tr>
          </tbody>
        </table>
      </div>

      <div class="prog-card" style="margin-bottom:20px;">
        <div class="prog-card-header"><h3>Duplicate Policy</h3></div>
        <div class="prog-card-body" style="font-size:12px;line-height:1.8;color:var(--prog-muted);">
          <p>If a vulnerability was already reported, your report will be marked <strong>Duplicate</strong>. The original reporter receives credit and bounty.</p>
          <p style="margin-top:8px;">Duplicates are acknowledged and the researcher is still listed on the <a href="/program/hall-of-fame" style="color:#25855A;">Hall of Fame</a> for their first valid finding.</p>
        </div>
      </div>

      <div class="prog-card">
        <div class="prog-card-header"><h3>Report Writing Tips</h3></div>
        <div class="prog-card-body" style="font-size:12px;line-height:1.9;color:var(--prog-muted);">
          <div>📌 Title format: <strong>[Type] in [Location] allows [Impact]</strong></div>
          <div>📌 Steps must be reproducible in under 5 minutes</div>
          <div>📌 Always include a working PoC (curl, Burp, screenshot)</div>
          <div>📌 State real-world impact — what can an attacker actually do?</div>
          <div>📌 Suggest a fix — shows professionalism</div>
          <div>📌 CVSS score helps justify your severity rating</div>
          <div style="margin-top:10px;"><a href="/program/examples/accepted" style="color:#25855A;">View example accepted report →</a></div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/program-footer') %>
