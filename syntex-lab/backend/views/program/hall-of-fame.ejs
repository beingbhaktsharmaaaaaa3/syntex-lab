<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div style="margin-bottom:20px;"><h1 style="font-size:22px;font-weight:800;">Hall of Fame</h1><p style="color:var(--prog-muted);font-size:13px;">Recognising researchers who help keep Syntex Solutions secure.</p></div>
  <div class="prog-card">
    <table class="prog-table">
      <thead><tr><th>Rank</th><th>Researcher</th><th>Country</th><th>Total Bugs</th><th>Critical</th><th>Total Bounty</th><th>Since</th></tr></thead>
      <tbody>
        <% hof.forEach(r => { %>
        <tr>
          <td><% if(r.rank===1){%>🥇<%}else if(r.rank===2){%>🥈<%}else if(r.rank===3){%>🥉<%}else{%><span style="color:var(--prog-muted);font-weight:700;">#<%=r.rank%></span><%}%></td>
          <td><div style="font-weight:700;"><%= r.researcher_name %></div><div style="font-size:11px;color:#25855A;">@<%= r.handle %></div></td>
          <td style="font-size:12px;"><%= r.country||'—' %></td>
          <td><span class="prog-badge prog-badge-blue"><%= r.bugs_found %></span></td>
          <td><span class="prog-badge prog-badge-red"><%= r.critical_bugs %></span></td>
          <td style="font-weight:700;color:#25855A;">$<%= parseFloat(r.total_bounty).toLocaleString() %></td>
          <td style="font-size:11px;color:var(--prog-muted);"><%= r.joined_year %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <div style="padding:14px 20px;border-top:1px solid #F7FAFC;font-size:12px;color:var(--prog-muted);">
      Want your name here? <a href="/program/submit" style="color:#25855A;">Submit a valid report</a> to earn recognition.
    </div>
  </div>
</div>
<%- include('../partials/program-footer') %>
