<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div style="margin-bottom:20px;">
    <div style="font-size:12px;color:var(--prog-muted);margin-bottom:4px;"><a href="/program" style="color:#25855A;text-decoration:none;">Program</a> › Scope</div>
    <h1 style="font-size:22px;font-weight:800;color:var(--prog-dark);">Program Scope</h1>
    <p style="color:var(--prog-muted);font-size:13px;">Only test assets explicitly listed as in-scope. All other systems are out-of-scope.</p>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

    <!-- In Scope -->
    <div class="prog-card">
      <div class="prog-card-header" style="background:#F0FFF4;border-bottom-color:#C6F6D5;">
        <h3 style="color:#22543D;">✅ In-Scope Assets</h3>
      </div>
      <table class="prog-table">
        <thead><tr><th>Asset</th><th>Type</th><th>Notes</th></tr></thead>
        <tbody>
          <% [
            {a:'syntex.local',          t:'Web App',    n:'All features — full scope'},
            {a:'www.syntex.local',       t:'Web App',    n:'Alias for syntex.local'},
            {a:'api.syntex.local',       t:'REST API',   n:'v1, v2, GraphQL, WebSocket'},
            {a:'admin.syntex.local',     t:'Admin',      n:'Admin panel — bypass in scope'},
            {a:'dev.syntex.local',       t:'Dev Env',    n:'Verbose errors, extra vulns'},
            {a:'staging.syntex.local',   t:'Staging',    n:'Full features, less hardened'},
            {a:'cdn.syntex.local',       t:'CDN',        n:'Source maps, static assets'},
            {a:'program.syntex.local',   t:'Platform',   n:'This platform — self-test OK'},
            {a:'localhost:3000',          t:'Direct',     n:'Direct app, bypasses nginx'},
            {a:'127.0.0.1:3000',          t:'Direct',     n:'Same as above'},
            {a:'127.0.0.1:5432',          t:'Database',   n:'If reachable via SSRF'},
          ].forEach(r => { %>
          <tr>
            <td><code style="font-size:11px;"><%= r.a %></code></td>
            <td><span class="prog-badge prog-badge-green" style="font-size:10px;"><%= r.t %></span></td>
            <td style="font-size:11px;color:var(--prog-muted);"><%= r.n %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Out of Scope -->
    <div class="prog-card">
      <div class="prog-card-header" style="background:#FFF5F5;border-bottom-color:#FED7D7;">
        <h3 style="color:#742A2A;">❌ Out-of-Scope</h3>
      </div>
      <table class="prog-table">
        <thead><tr><th>Asset / Action</th><th>Reason</th></tr></thead>
        <tbody>
          <% [
            {a:'mail.syntex.local',       r:'Email infra — not in scope'},
            {a:'vpn.syntex.local',        r:'VPN — not in scope'},
            {a:'backup.syntex.local',     r:'Backup service — dead'},
            {a:'intranet.syntex.local',   r:'Internal only — not tested'},
            {a:'DoS / DDoS attacks',      r:'Zero tolerance'},
            {a:'Social engineering',      r:'No phishing other lab users'},
            {a:'Physical security',       r:'Out of scope'},
            {a:'Third-party services',    r:'Stripe, AWS — not our assets'},
            {a:'Automated scanning only', r:'Must verify manually'},
            {a:'Attacks outside lab',     r:'Only test local lab environment'},
          ].forEach(r => { %>
          <tr>
            <td style="font-size:12px;font-weight:600;"><%= r.a %></td>
            <td style="font-size:12px;color:var(--prog-muted);"><%= r.r %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- API Endpoints in scope -->
  <div class="prog-card" style="margin-bottom:20px;">
    <div class="prog-card-header"><h3>API Endpoints — In Scope</h3></div>
    <table class="prog-table">
      <thead><tr><th>Method</th><th>Endpoint</th><th>Auth</th><th>Notes</th></tr></thead>
      <tbody>
        <% [
          {m:'POST',e:'/login',                    a:'None',   n:'SQLi, rate limit bypass, open redirect'},
          {m:'GET', e:'/api/v1/users/:id',          a:'None',   n:'IDOR — sensitive fields returned'},
          {m:'GET', e:'/api/v1/orders',             a:'JWT',    n:'Returns all orders — context ignored'},
          {m:'POST',e:'/api/v1/fetch',              a:'None',   n:'SSRF endpoint'},
          {m:'POST',e:'/graphql',                   a:'Optional',n:'Introspection on, IDOR in queries'},
          {m:'GET', e:'/api/v2/users/export',       a:'None',   n:'Unauthenticated user dump'},
          {m:'GET', e:'/api/v2/internal/config',    a:'None',   n:'Full config with secrets'},
          {m:'GET', e:'/.env',                      a:'None',   n:'Credentials exposed'},
          {m:'GET', e:'/debug',                     a:'None',   n:'All env vars exposed'},
          {m:'WS',  e:'/ws/chat',                   a:'None',   n:'WebSocket — no auth, IDOR rooms'},
          {m:'GET', e:'/oauth/authorize',           a:'Session',n:'Missing state, open redirect'},
          {m:'POST',e:'/race/withdraw',             a:'Session',n:'Race condition — wallet'},
        ].forEach(r => { %>
        <tr>
          <td><span class="prog-badge prog-badge-blue" style="font-size:10px;"><%= r.m %></span></td>
          <td><code style="font-size:11px;"><%= r.e %></code></td>
          <td style="font-size:11px;"><%= r.a %></td>
          <td style="font-size:11px;color:var(--prog-muted);"><%= r.n %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Subdomain discovery -->
  <div class="prog-card">
    <div class="prog-card-header"><h3>Subdomain Discovery</h3><span style="font-size:12px;color:var(--prog-muted);">27 subdomains — find them all</span></div>
    <div class="prog-card-body">
      <p style="font-size:13px;color:var(--prog-muted);margin-bottom:14px;">⚠️ <strong>subfinder does not work on .local domains</strong> — it uses certificate transparency logs which don't exist for local domains. Use these tools instead:</p>
      <pre style="font-size:12px;background:#1A202C;color:#68D391;padding:16px;border-radius:6px;overflow-x:auto;">
# Start the lab DNS server first:
docker compose up dns

# Then use gobuster with the lab DNS resolver:
gobuster dns -d syntex.local --resolver 127.0.0.1:5353 -w wordlist.txt -t 30

# Or ffuf vhost fuzzing (no DNS needed):
ffuf -u http://127.0.0.1 -H "Host: FUZZ.syntex.local" -w wordlist.txt -mc 200,301,302,403,503 -t 40

# After finding subdomains, probe with httpx:
cat found_subs.txt | httpx -status-code -title -tech-detect -web-server</pre>
    </div>
  </div>
</div>
<%- include('../partials/program-footer') %>
