<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
    <div>
      <div style="font-size:12px;color:var(--prog-muted);margin-bottom:4px;"><a href="/program" style="color:#25855A;text-decoration:none;">Program</a> › Hints</div>
      <h1 style="font-size:22px;font-weight:800;">💡 Hint System</h1>
      <p style="color:var(--prog-muted);font-size:13px;margin-top:4px;">Three progressive levels per vulnerability. Unlock only what you need — solutions stay separate.</p>
    </div>
    <a href="/program/submit" class="prog-btn prog-btn-green">+ Submit Report</a>
  </div>

  <%
    const catColors = {
      'SQL Injection':'prog-badge-red','XSS':'prog-badge-yellow','IDOR':'prog-badge-blue',
      'CSRF':'prog-badge-gray','JWT':'prog-badge-purple','SSRF':'prog-badge-red',
      'LFI':'prog-badge-yellow','Command Injection':'prog-badge-red','Open Redirect':'prog-badge-gray',
      'Broken Access':'prog-badge-blue','Business Logic':'prog-badge-yellow',
      'Exposure':'prog-badge-gray','GraphQL':'prog-badge-purple','OAuth/SSO':'prog-badge-blue',
      'WebSocket':'prog-badge-gray','Race Condition':'prog-badge-red','Rate Limiting':'prog-badge-gray',
      'Auth Bypass':'prog-badge-red','File Upload':'prog-badge-yellow',
    };
    const diffColor = {easy:'prog-badge-green',medium:'prog-badge-yellow',hard:'prog-badge-red'};
  %>

  <% Object.entries(grouped).forEach(([cat, vulns]) => { %>
  <div class="prog-card" style="margin-bottom:16px;">
    <div class="prog-card-header">
      <div style="display:flex;align-items:center;gap:8px;">
        <span class="prog-badge <%= catColors[cat]||'prog-badge-gray' %>"><%= cat %></span>
        <span style="font-size:12px;color:var(--prog-muted);"><%= vulns.length %> vuln<%= vulns.length!==1?'s':'' %></span>
      </div>
    </div>
    <table class="prog-table">
      <thead><tr><th>Vulnerability</th><th>Endpoint</th><th>Difficulty</th><th>Hints</th><th></th></tr></thead>
      <tbody>
        <% vulns.forEach(v => { %>
        <tr>
          <td style="font-weight:600;font-size:13px;"><%= v.title %></td>
          <td><code style="font-size:11px;color:var(--prog-muted);"><%= v.endpoint %></code></td>
          <td><span class="prog-badge <%= diffColor[v.difficulty]||'prog-badge-gray' %>"><%= v.difficulty %></span></td>
          <td>
            <div style="display:flex;gap:4px;">
              <% [1,2,3].forEach(l => { %>
              <div style="width:12px;height:12px;border-radius:50%;background:var(--prog-border);" title="Level <%=l%>"></div>
              <% }) %>
            </div>
          </td>
          <td><a href="/program/hints/<%= v.slug %>" class="prog-btn prog-btn-outline" style="font-size:11px;padding:4px 10px;">View Hints →</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% }) %>

  <div class="prog-card">
    <div class="prog-card-body" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <div style="font-weight:700;font-size:14px;">Ready to exploit? Write it up.</div>
        <div style="font-size:12px;color:var(--prog-muted);">Found a vulnerability? Submit a report with the flag for instant verification.</div>
      </div>
      <div style="display:flex;gap:8px;">
        <a href="/program/submit"     class="prog-btn prog-btn-green">Submit Report →</a>
        <a href="/program/challenges" class="prog-btn prog-btn-outline">Vuln Chains →</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/program-footer') %>
