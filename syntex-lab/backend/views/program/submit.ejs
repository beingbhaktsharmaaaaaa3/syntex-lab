<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div style="margin-bottom:20px;">
    <div style="font-size:12px;color:var(--prog-muted);margin-bottom:4px;"><a href="/program" style="color:#25855A;text-decoration:none;">Program</a> › <a href="/program/reports" style="color:#25855A;text-decoration:none;">Reports</a> › New</div>
    <h1 style="font-size:22px;font-weight:800;">Submit Bug Report</h1>
  </div>
  <% if (error) { %><div style="background:#FFF5F5;border:1px solid #FED7D7;color:#742A2A;padding:12px 16px;border-radius:6px;margin-bottom:16px;font-size:13px;"><%= error %></div><% } %>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;align-items:start;">
    <div>
      <div class="prog-card">
        <div class="prog-card-header"><h3>Bug Report</h3><span style="font-size:12px;color:var(--prog-muted);">* required</span></div>
        <div class="prog-card-body">
          <form action="/program/submit" method="POST">

            <!-- Flag verification box -->
            <div style="background:linear-gradient(135deg,#EBF8FF,#F0FFF4);border:2px solid #48BB78;border-radius:8px;padding:18px;margin-bottom:24px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
                <span style="font-size:20px;">🚩</span>
                <div>
                  <div style="font-weight:700;font-size:14px;color:var(--prog-dark);">Instant Verification via Flag</div>
                  <div style="font-size:12px;color:var(--prog-muted);">Found a FLAG{...} while exploiting? Paste it here to auto-verify your report instantly.</div>
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div>
                  <label style="font-size:11px;font-weight:700;color:var(--prog-muted);text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:4px;">Vulnerability (flag match)</label>
                  <select name="flag_slug" style="width:100%;padding:8px 10px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;">
                    <option value="">— Select vulnerability —</option>
                    <% const cats = {}; availableFlags.forEach(f => { if(!cats[f.category]) cats[f.category]=[]; cats[f.category].push(f); }); %>
                    <% Object.entries(cats).forEach(([cat,fs]) => { %>
                    <optgroup label="<%= cat %>">
                      <% fs.forEach(f => { %><option value="<%= f.slug %>"><%= f.vuln_title %> (+<%= f.points %>pts)</option><% }) %>
                    </optgroup>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <label style="font-size:11px;font-weight:700;color:var(--prog-muted);text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:4px;">Flag Value</label>
                  <input type="text" name="flag_submitted" placeholder="FLAG{paste_here}" style="width:100%;padding:8px 10px;border:1px solid #E2E8F0;border-radius:6px;font-size:12px;font-family:monospace;">
                </div>
              </div>
            </div>

            <div style="margin-bottom:16px;">
              <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Report Title *</label>
              <input type="text" name="title" required placeholder='e.g. "SQL Injection in /login allows authentication bypass"' style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;box-sizing:border-box;">
              <div style="font-size:11px;color:var(--prog-muted);margin-top:4px;">Format: [Vuln Type] in [Location] allows [Impact]</div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
              <div>
                <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Vulnerability Type *</label>
                <select name="vuln_type" required style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;">
                  <option value="">— Select —</option>
                  <optgroup label="Injection"><option value="sqli">SQL Injection</option><option value="cmd_injection">Command Injection</option><option value="lfi">LFI / Path Traversal</option><option value="ssrf">SSRF</option></optgroup>
                  <optgroup label="XSS"><option value="xss_reflected">XSS — Reflected</option><option value="xss_stored">XSS — Stored</option><option value="xss_dom">XSS — DOM</option></optgroup>
                  <optgroup label="Access Control"><option value="idor">IDOR</option><option value="broken_access">Broken Access Control</option><option value="auth_bypass">Auth Bypass</option><option value="csrf">CSRF</option></optgroup>
                  <optgroup label="Auth"><option value="jwt">JWT Vulnerability</option><option value="oauth">OAuth/SSO Flaw</option><option value="weak_crypto">Weak Cryptography</option><option value="rate_limit">Rate Limit Bypass</option></optgroup>
                  <optgroup label="Modern"><option value="graphql">GraphQL Vulnerability</option><option value="websocket">WebSocket Auth Flaw</option><option value="race_condition">Race Condition</option><option value="cors">CORS Misconfiguration</option></optgroup>
                  <optgroup label="Other"><option value="open_redirect">Open Redirect</option><option value="file_upload">File Upload Bypass</option><option value="business_logic">Business Logic</option><option value="exposure">Exposed Secrets</option><option value="other">Other</option></optgroup>
                </select>
              </div>
              <div>
                <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Severity *</label>
                <select name="severity" required style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;">
                  <option value="">— Select —</option>
                  <option value="critical">🔴 Critical (P1) — CVSS 9.0+</option>
                  <option value="high">🟠 High (P2) — CVSS 7.0–8.9</option>
                  <option value="medium">🟡 Medium (P3) — CVSS 4.0–6.9</option>
                  <option value="low">🟢 Low (P4) — CVSS 0.1–3.9</option>
                  <option value="info">⚪ Informative (P5)</option>
                </select>
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
              <div>
                <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">CVSS Score</label>
                <input type="number" name="cvss_score" min="0" max="10" step="0.1" placeholder="e.g. 8.5" style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;box-sizing:border-box;">
              </div>
              <div>
                <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Affected Endpoint *</label>
                <input type="text" name="affected_url" required placeholder="e.g. POST /login" style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;box-sizing:border-box;">
              </div>
            </div>

            <div style="margin-bottom:16px;">
              <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Steps to Reproduce *</label>
              <textarea name="steps" rows="7" required placeholder="1. Navigate to /login&#10;2. Enter username: admin'--&#10;3. Enter any password&#10;4. Click Login&#10;5. Authenticated as admin without valid credentials" style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;resize:vertical;box-sizing:border-box;"></textarea>
              <div style="font-size:11px;color:var(--prog-muted);margin-top:4px;">Numbered steps. Reproducible in &lt;5 minutes.</div>
            </div>

            <div style="margin-bottom:16px;">
              <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Impact *</label>
              <textarea name="impact" rows="4" required placeholder="What can an attacker achieve? What data is exposed? How many users are affected?" style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;resize:vertical;box-sizing:border-box;"></textarea>
            </div>

            <div style="margin-bottom:16px;">
              <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Proof of Concept</label>
              <textarea name="proof_of_concept" rows="5" placeholder="Paste your payload, curl command, or Burp request here." style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:12px;font-family:monospace;resize:vertical;box-sizing:border-box;"></textarea>
            </div>

            <div style="margin-bottom:20px;">
              <label style="font-size:12px;font-weight:700;color:var(--prog-dark);display:block;margin-bottom:5px;">Suggested Fix</label>
              <textarea name="suggested_fix" rows="3" placeholder="What change would fix this vulnerability?" style="width:100%;padding:9px 12px;border:1px solid #E2E8F0;border-radius:6px;font-size:13px;resize:vertical;box-sizing:border-box;"></textarea>
            </div>

            <div style="display:flex;gap:10px;">
              <button type="submit" class="prog-btn prog-btn-green" style="font-size:14px;padding:10px 24px;">Submit Report</button>
              <a href="/program/reports" class="prog-btn prog-btn-outline">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div>
      <div class="prog-card" style="margin-bottom:16px;border-color:#48BB78;border-width:2px;">
        <div class="prog-card-header" style="background:#F0FFF4;"><h3 style="color:#22543D;">How Verification Works</h3></div>
        <div class="prog-card-body" style="font-size:12px;line-height:1.9;color:var(--prog-muted);">
          <div>1️⃣ Exploit the vulnerability</div>
          <div>2️⃣ Find the <code>FLAG{...}</code> at the proof point</div>
          <div>3️⃣ Submit report with the flag</div>
          <div style="color:#25855A;font-weight:700;margin-top:6px;">✅ Instant auto-verified!</div>
          <div style="margin-top:10px;padding-top:10px;border-top:1px solid #E2E8F0;">No flag? Report goes to manual triage — include a thorough PoC.</div>
        </div>
      </div>

      <div class="prog-card" style="margin-bottom:16px;">
        <div class="prog-card-header"><h3>Good Report Checklist</h3></div>
        <div class="prog-card-body" style="font-size:12px;line-height:1.9;color:var(--prog-muted);">
          <div>☐ Clear title: [Type] in [Location] → [Impact]</div>
          <div>☐ Numbered steps — reproducible</div>
          <div>☐ Working PoC (curl, Burp, screenshot)</div>
          <div>☐ Real-world impact explained</div>
          <div>☐ Correct severity (don't over-inflate)</div>
          <div>☐ Suggested fix included</div>
        </div>
      </div>

      <div class="prog-card">
        <div class="prog-card-header"><h3>Need Help?</h3></div>
        <div class="prog-card-body" style="display:flex;flex-direction:column;gap:8px;">
          <% if(mode !== 'realistic'){ %>
          <a href="/program/hints" class="prog-btn prog-btn-outline" style="text-align:center;justify-content:center;">💡 Browse Hints</a>
          <a href="/program/challenges" class="prog-btn prog-btn-outline" style="text-align:center;justify-content:center;">⚡ Vuln Chains</a>
          <a href="/program/flags" class="prog-btn prog-btn-outline" style="text-align:center;justify-content:center;">🚩 Flag Hunt</a>
          <% } %>
          <a href="/program/examples/accepted" class="prog-btn prog-btn-outline" style="text-align:center;justify-content:center;">📄 Example Report</a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/program-footer') %>
