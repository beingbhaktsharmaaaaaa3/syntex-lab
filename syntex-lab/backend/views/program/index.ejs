<%- include('../partials/program-navbar') %>

<div class="prog-page">

  <!-- Hero -->
  <div class="prog-card" style="background:linear-gradient(135deg,#1A202C,#2D3748);color:#fff;border:none;margin-bottom:24px;">
    <div class="prog-card-body" style="padding:36px;">
      <div style="display:flex;align-items:flex-start;gap:20px;flex-wrap:wrap;">
        <div style="width:56px;height:56px;background:#25855A;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;">🛡️</div>
        <div style="flex:1;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;flex-wrap:wrap;">
            <h1 style="font-size:22px;font-weight:800;margin:0;">Syntex Solutions Bug Bounty</h1>
            <span class="prog-badge prog-badge-green">Public Program</span>
            <span class="prog-badge prog-badge-green">Bounties Paid</span>
            <span class="prog-badge prog-badge-blue">Safe Harbour</span>
          </div>
          <p style="opacity:0.7;font-size:13px;max-width:600px;line-height:1.6;">Help us keep Syntex Solutions secure. We invite security researchers to find vulnerabilities across our platform and APIs. Responsible disclosure is rewarded.</p>
          <div style="display:flex;gap:10px;margin-top:16px;flex-wrap:wrap;">
            <a href="/program/submit" class="prog-btn prog-btn-green">Submit a Report →</a>
            <a href="/program/scope"  class="prog-btn prog-btn-outline" style="color:#fff;border-color:rgba(255,255,255,0.3);">View Scope</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats row -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:16px;margin-bottom:24px;">
    <% [
      {label:'Total Reports',  value:stats.total_reports},
      {label:'Accepted',       value:stats.accepted},
      {label:'Bounties Paid',  value:'$'+parseFloat(stats.total_paid||0).toLocaleString()},
      {label:'Flags to Hunt',  value:stats.total_flags},
    ].forEach(s => { %>
    <div class="prog-card"><div class="prog-stat">
      <div class="prog-stat-value"><%= s.value %></div>
      <div class="prog-stat-label"><%= s.label %></div>
    </div></div>
    <% }) %>
  </div>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;align-items:start;">
    <div>

      <!-- Severity & Rewards -->
      <div class="prog-card">
        <div class="prog-card-header"><h3>Severity Levels & Rewards</h3></div>
        <table class="prog-table">
          <thead><tr><th>Level</th><th>Severity</th><th>CVSS</th><th>Examples</th><th>Reward</th></tr></thead>
          <tbody>
            <% [
              {p:'P1',sev:'Critical',cvss:'9.0–10.0',ex:'RCE, auth bypass, mass data dump',reward:'$1,000–$3,000',color:'prog-badge-red'},
              {p:'P2',sev:'High',    cvss:'7.0–8.9', ex:'Stored XSS admin, SSRF internal, JWT bypass',reward:'$500–$1,000',color:'prog-badge-yellow'},
              {p:'P3',sev:'Medium',  cvss:'4.0–6.9', ex:'CSRF, reflected XSS, IDOR non-sensitive',reward:'$100–$500',color:'prog-badge-blue'},
              {p:'P4',sev:'Low',     cvss:'0.1–3.9', ex:'Info disclosure, rate limit, predictable token',reward:'$50–$100',color:'prog-badge-green'},
              {p:'P5',sev:'Info',    cvss:'N/A',      ex:'Best practices, version disclosure',reward:'Acknowledged',color:'prog-badge-gray'},
            ].forEach(r => { %>
            <tr>
              <td><span class="prog-badge <%= r.color %>"><%= r.p %></span></td>
              <td style="font-weight:700;"><%= r.sev %></td>
              <td style="font-size:12px;color:var(--prog-muted);"><%= r.cvss %></td>
              <td style="font-size:12px;color:var(--prog-muted);"><%= r.ex %></td>
              <td style="font-weight:700;color:#25855A;"><%= r.reward %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- In Scope preview -->
      <div class="prog-card" style="margin-top:20px;">
        <div class="prog-card-header">
          <h3>In-Scope Assets</h3>
          <a href="/program/scope" class="prog-btn prog-btn-outline" style="font-size:12px;padding:5px 10px;">Full Scope →</a>
        </div>
        <div class="prog-card-body" style="padding:0;">
          <% [
            {a:'syntex.local',      t:'Web App',   desc:'Full application — all features, all endpoints'},
            {a:'api.syntex.local',  t:'API',        desc:'REST API v1 + v2 + GraphQL'},
            {a:'admin.syntex.local',t:'Admin Panel',desc:'Admin panel — bypass testing in scope'},
            {a:'dev.syntex.local',  t:'Dev Env',    desc:'Development environment'},
            {a:'staging.syntex.local',t:'Staging',  desc:'Staging environment'},
            {a:'cdn.syntex.local',  t:'CDN',        desc:'Static assets — source maps in scope'},
            {a:'program.syntex.local',t:'Platform', desc:'This bug bounty platform — self-test OK'},
          ].forEach(r => { %>
          <div style="display:flex;align-items:center;gap:12px;padding:12px 20px;border-bottom:1px solid #F7FAFC;">
            <span style="color:#25855A;font-weight:800;font-size:16px;">✓</span>
            <div style="flex:1;">
              <code style="font-size:12px;font-weight:600;"><%= r.a %></code>
              <span class="prog-badge prog-badge-gray" style="margin-left:6px;font-size:10px;"><%= r.t %></span>
            </div>
            <span style="font-size:12px;color:var(--prog-muted);"><%= r.desc %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Example reports -->
      <div class="prog-card" style="margin-top:20px;">
        <div class="prog-card-header"><h3>Example Reports</h3><span style="font-size:12px;color:var(--prog-muted);">Learn what good reports look like</span></div>
        <div class="prog-card-body" style="padding:0;">
          <% [
            {href:'/program/examples/accepted',       label:'✅ Accepted',      desc:'SQL injection with full exploitation PoC',       badge:'prog-badge-green'},
            {href:'/program/examples/duplicate',      label:'🔄 Duplicate',     desc:'Stored XSS — already reported by another researcher',badge:'prog-badge-gray'},
            {href:'/program/examples/informative',    label:'ℹ️ Informative',   desc:'Missing security headers — no real impact',       badge:'prog-badge-blue'},
            {href:'/program/examples/not-applicable', label:'❌ N/A',            desc:'Self-XSS — only affects the attacker themselves',  badge:'prog-badge-yellow'},
          ].forEach(e => { %>
          <a href="<%= e.href %>" style="display:flex;align-items:center;gap:14px;padding:14px 20px;border-bottom:1px solid #F7FAFC;text-decoration:none;color:inherit;">
            <span class="prog-badge <%= e.badge %>"><%= e.label %></span>
            <span style="font-size:13px;flex:1;"><%= e.desc %></span>
            <span style="font-size:12px;color:#25855A;">View →</span>
          </a>
          <% }) %>
        </div>
      </div>
    </div>

    <div>
      <!-- Quick links -->
      <div class="prog-card">
        <div class="prog-card-header"><h3>Quick Start</h3></div>
        <div class="prog-card-body" style="display:flex;flex-direction:column;gap:10px;">
          <a href="/program/scope"   class="prog-btn prog-btn-outline" style="justify-content:flex-start;">📋 Read the Scope</a>
          <a href="/program/rules"   class="prog-btn prog-btn-outline" style="justify-content:flex-start;">📜 Rules of Engagement</a>
          <a href="/program/submit"  class="prog-btn prog-btn-green"   style="justify-content:flex-start;">+ Submit a Report</a>
          <% if(locals.lab && lab.showHints){ %>
          <a href="/program/hints"           class="prog-btn prog-btn-outline" style="justify-content:flex-start;">💡 Hints</a>
          <a href="/program/challenges"      class="prog-btn prog-btn-outline" style="justify-content:flex-start;">⚡ Vuln Chains</a>
          <a href="/program/flags"   class="prog-btn prog-btn-outline" style="justify-content:flex-start;">🚩 Flag Hunt</a>
          <% } %>
        </div>
      </div>

      <!-- Target site link -->
      <div class="prog-card" style="margin-top:20px;">
        <div class="prog-card-header"><h3>Target Website</h3></div>
        <div class="prog-card-body" style="font-size:13px;">
          <p style="color:var(--prog-muted);margin-bottom:12px;">The vulnerable target is a separate site from this platform. Hunt vulnerabilities there, then submit reports here.</p>
          <a href="http://syntex.local" target="_blank" class="prog-btn prog-btn-outline" style="width:100%;justify-content:center;text-align:center;">
            🎯 Open syntex.local →
          </a>
          <div style="margin-top:10px;font-size:11px;color:var(--prog-muted);">
            <div style="margin-bottom:4px;">Also test:</div>
            <% ['api.syntex.local','admin.syntex.local','dev.syntex.local','cdn.syntex.local'].forEach(s => { %>
            <div>• <a href="http://<%= s %>" style="color:#25855A;" target="_blank"><%= s %></a></div>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Hall of Fame preview -->
      <div class="prog-card" style="margin-top:20px;">
        <div class="prog-card-header">
          <h3>Top Researchers</h3>
          <a href="/program/hall-of-fame" style="font-size:12px;color:#25855A;text-decoration:none;">View all →</a>
        </div>
        <table class="prog-table">
          <tbody>
            <% hof.forEach((r,i) => { %>
            <tr>
              <td style="font-weight:800;color:var(--prog-muted);">#<%= r.rank %></td>
              <td>
                <div style="font-weight:600;font-size:13px;"><%= r.researcher_name %></div>
                <div style="font-size:11px;color:var(--prog-muted);">@<%= r.handle %></div>
              </td>
              <td style="font-weight:700;color:#25855A;">$<%= parseFloat(r.total_bounty).toLocaleString() %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/program-footer') %>
