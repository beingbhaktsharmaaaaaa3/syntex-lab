<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div style="margin-bottom:20px;">
    <h1 style="font-size:22px;font-weight:800;">Leaderboard</h1>
    <p style="color:var(--prog-muted);font-size:13px;">Ranked by total points. First bloods earn +50% bonus points.</p>
  </div>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start;">
    <div>
      <div class="prog-card">
        <div class="prog-card-header"><h3>Researcher Rankings</h3></div>
        <table class="prog-table">
          <thead>
            <tr><th>Rank</th><th>Researcher</th><th>Total Points</th><th>Bugs Found</th><th>🩸 1st Bloods</th></tr>
          </thead>
          <tbody>
            <% if(!reporters.length){ %>
            <tr><td colspan="5" style="text-align:center;color:var(--prog-muted);padding:40px;">
              No rankings yet. <a href="/program/submit" style="color:#25855A;">Submit the first report!</a>
            </td></tr>
            <% } %>
            <% reporters.forEach((r,i) => { %>
            <tr style="<%= i<3?'background:#FAFAFA;':'' %>">
              <td>
                <span style="font-size:18px;">
                  <% if(i===0){%>🥇<%}else if(i===1){%>🥈<%}else if(i===2){%>🥉<%}else{%><span style="font-weight:700;color:var(--prog-muted);">#<%= i+1 %></span><%}%>
                </span>
              </td>
              <td>
                <div style="font-weight:700;font-size:13px;"><%= r.first_name ? r.first_name+' '+(r.last_name||'') : r.username %></div>
                <div style="font-size:11px;color:var(--prog-muted);">@<%= r.username %></div>
              </td>
              <td>
                <span style="font-size:16px;font-weight:800;color:#25855A;"><%= r.total_points %></span>
                <span style="font-size:11px;color:var(--prog-muted);"> pts</span>
              </td>
              <td>
                <span class="prog-badge prog-badge-green"><%= r.valid_reports %> bugs</span>
              </td>
              <td>
                <% if(r.first_bloods_count>0){ %>
                <span class="prog-badge" style="background:#FED7D7;color:#742A2A;">🩸 <%= r.first_bloods_count %></span>
                <% } else { %>
                <span style="color:var(--prog-muted);font-size:12px;">—</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <div class="prog-card" style="margin-bottom:16px;">
        <div class="prog-card-header"><h3>Points System</h3></div>
        <div class="prog-card-body" style="font-size:12px;line-height:1.9;color:var(--prog-muted);">
          <div style="margin-bottom:8px;">
            <% [['Critical Bug','250 pts'],['High Bug','200 pts'],['Medium Bug','150 pts'],['Low Bug','100 pts'],['Info','50 pts'],['🩸 First Blood','+50% bonus']].forEach(([k,v])=>{ %>
            <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #F7FAFC;">
              <span><%= k %></span><span style="font-weight:700;color:#25855A;"><%= v %></span>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="prog-card" style="margin-bottom:16px;">
        <div class="prog-card-header">
          <h3>Hall of Fame</h3>
          <a href="/program/hall-of-fame" style="font-size:12px;color:#25855A;text-decoration:none;">View all →</a>
        </div>
        <table class="prog-table">
          <tbody>
            <% hof.slice(0,5).forEach(r=>{ %>
            <tr>
              <td style="font-weight:800;color:var(--prog-muted);">#<%= r.rank %></td>
              <td><div style="font-weight:600;font-size:13px;"><%= r.researcher_name %></div><div style="font-size:11px;color:#25855A;">@<%= r.handle %></div></td>
              <td style="font-weight:700;color:#25855A;">$<%= parseFloat(r.total_bounty).toLocaleString() %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="prog-card">
        <div class="prog-card-header"><h3>Climb the Ranks</h3></div>
        <div class="prog-card-body" style="display:flex;flex-direction:column;gap:8px;">
          <a href="/program/submit"  class="prog-btn prog-btn-green" style="justify-content:center;">+ Submit Report</a>
          <a href="/program/flags"   class="prog-btn prog-btn-outline" style="justify-content:center;">🚩 Flag Hunt</a>
          <a href="/program/challenges" class="prog-btn prog-btn-outline" style="justify-content:center;">⚡ Vuln Chains</a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/program-footer') %>
