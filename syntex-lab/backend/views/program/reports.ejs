<%- include('../partials/program-navbar') %>
<div class="prog-page">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
    <div>
      <div style="font-size:12px;color:var(--prog-muted);margin-bottom:4px;"><a href="/program" style="color:#25855A;text-decoration:none;">Program</a> › My Reports</div>
      <h1 style="font-size:22px;font-weight:800;">My Reports</h1>
    </div>
    <a href="/program/submit" class="prog-btn prog-btn-green">+ New Report</a>
  </div>

  <% const statColors={new:'prog-badge-blue',needs_more_info:'prog-badge-yellow',accepted:'prog-badge-green',duplicate:'prog-badge-gray',informative:'prog-badge-blue',not_applicable:'prog-badge-red',resolved:'prog-badge-green'};
     const statLabels={new:'🆕 New',needs_more_info:'ℹ️ Needs Info',accepted:'✅ Accepted',duplicate:'🔄 Duplicate',informative:'ℹ️ Informative',not_applicable:'❌ N/A',resolved:'✔️ Resolved'};
     const sevColors={critical:'prog-badge-red',high:'prog-badge-yellow',medium:'prog-badge-blue',low:'prog-badge-green',info:'prog-badge-gray'}; %>

  <% if(reports.length === 0) { %>
  <div class="prog-card"><div style="text-align:center;padding:48px 24px;">
    <div style="font-size:48px;margin-bottom:12px;">🔍</div>
    <h3 style="font-size:16px;font-weight:700;margin-bottom:6px;">No reports yet</h3>
    <p style="color:var(--prog-muted);font-size:13px;margin-bottom:16px;">Start hunting vulnerabilities on <a href="http://syntex.local" style="color:#25855A;">syntex.local</a> and submit your first report.</p>
    <a href="/program/submit" class="prog-btn prog-btn-green">Submit First Report</a>
  </div></div>
  <% } else { %>
  <div class="prog-card">
    <table class="prog-table">
      <thead><tr><th>#</th><th>Title</th><th>Type</th><th>Severity</th><th>Status</th><th>Verified</th><th>Bounty</th><th>Date</th></tr></thead>
      <tbody>
        <% reports.forEach(r => { %>
        <tr>
          <td style="color:var(--prog-muted);font-size:11px;">#<%= r.id %></td>
          <td><a href="/program/reports/<%= r.id %>" style="color:var(--prog-dark);text-decoration:none;font-weight:600;font-size:13px;"><%= r.title.length>60?r.title.slice(0,60)+'…':r.title %></a></td>
          <td><span class="prog-badge prog-badge-gray" style="font-size:10px;"><%= r.vuln_type.replace(/_/g,' ') %></span></td>
          <td><span class="prog-badge <%= sevColors[r.severity]||'prog-badge-gray' %>"><%= r.severity %></span></td>
          <td><span class="prog-badge <%= statColors[r.status]||'prog-badge-gray' %>"><%= statLabels[r.status]||r.status %></span></td>
          <td style="font-size:13px;"><%= r.flag_verified?'✅':'⏳' %></td>
          <td style="font-weight:700;color:<%= r.bounty_amount>0?'#25855A':'var(--prog-muted)' %>;"><%= r.bounty_amount>0?'$'+parseFloat(r.bounty_amount).toLocaleString():'—' %></td>
          <td style="font-size:11px;color:var(--prog-muted);"><%= new Date(r.created_at).toLocaleDateString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<%- include('../partials/program-footer') %>
