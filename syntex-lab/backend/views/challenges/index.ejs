<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Vulnerability Chains</span>
      <div class="header-right">
        <a href="/program/hints" class="btn btn-secondary btn-sm">Hints</a>
        <a href="/profile/<%= user ? user.id : '' %>" class="header-user">
          <% if(user){%><div class="header-avatar"><%=((user.first_name||user.username).charAt(0)).toUpperCase()%></div><%}%>
        </a>
      </div>
    </div>
    <div class="page-body">
      <div class="page-header">
        <h1>Vulnerability Chains</h1>
        <p>Real bug bounty impact comes from chaining bugs. Each scenario shows how multiple low-to-medium findings combine into critical findings.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px;">
        <% const diffColor = {easy:'success',medium:'warning',hard:'danger'}; %>
        <% chains.forEach((c,i) => { %>
        <div class="card" style="display:flex;flex-direction:column;">
          <div class="card-header">
            <div>
              <div style="font-size:11px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;"><%= c.category %></div>
              <h3 style="font-size:14px;"><%= c.title %></h3>
            </div>
            <span class="badge badge-<%= diffColor[c.difficulty]||'gray' %>"><%= c.difficulty %></span>
          </div>
          <div class="card-body" style="flex:1;">
            <p style="font-size:13px;color:var(--text-muted);line-height:1.6;margin-bottom:14px;"><%= c.description %></p>

            <!-- Vuln tags -->
            <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:14px;">
              <% c.vulns.forEach(v => { %>
              <span style="background:var(--page-bg);border:1px solid var(--border);padding:2px 7px;border-radius:12px;font-size:11px;color:var(--text-muted);"><%= v %></span>
              <% }) %>
            </div>

            <!-- Steps preview -->
            <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:14px;">
              <% c.steps.slice(0,3).forEach((s,si) => { %>
              <div style="display:flex;gap:8px;align-items:flex-start;">
                <div style="width:18px;height:18px;border-radius:50%;background:var(--primary);color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;"><%= s.n %></div>
                <span style="font-size:12px;color:var(--text-muted);"><%= s.title %></span>
              </div>
              <% }) %>
              <% if(c.steps.length > 3) { %>
              <div style="font-size:11px;color:var(--text-light);padding-left:26px;">+ <%= c.steps.length-3 %> more steps…</div>
              <% } %>
            </div>
          </div>
          <div class="card-footer" style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:12px;color:var(--text-muted);">⏱ <%= c.time %></span>
            <a href="/program/challenges/<%= c.id %>" class="btn btn-primary btn-sm">Start Chain →</a>
          </div>
        </div>
        <% }) %>
      </div>

      <div class="card" style="margin-top:24px;">
        <div class="card-body" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
          <div>
            <div style="font-weight:700;font-size:14px;">Ready to document your findings?</div>
            <div style="font-size:12px;color:var(--text-muted);">After completing a chain, write it up as a professional bug report.</div>
          </div>
          <a href="/program/submit" class="btn btn-primary">Submit a Report →</a>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
