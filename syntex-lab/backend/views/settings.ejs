<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">Account Settings</span>
      <div class="header-right"><a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a></div>
    </div>
    <div class="page-body">
      <div class="page-header"><h1>Account Settings</h1><p>Manage your Syntex account preferences and security.</p></div>
      <% if (success) { %><div class="alert alert-success alert-auto-dismiss"><%= success %></div><% } %>
      <div style="max-width:580px;">
        <div class="card mb-4">
          <div class="card-header"><h3>Profile Information</h3></div>
          <div class="card-body">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">To edit name, department, bio and other profile fields, visit your <a href="/profile/<%= user.id %>/edit" style="color:var(--accent);">profile edit page</a>.</p>
            <table style="font-size:13px;width:100%;">
              <tr><td style="padding:5px 0;color:var(--text-muted);width:120px;">Username</td><td><%= user.username %></td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Email</td><td><%= user.email %></td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Role</td><td><span class="badge badge-<%= user.role==='admin'?'admin':user.role==='developer'?'dev':'gray' %>"><%= user.role %></span></td></tr>
            </table>
          </div>
        </div>

        <!-- VULNERABILITY: No CSRF tokens on any of these forms -->
        <div class="card mb-4" style="border-color:#FDE68A;">
          <div class="card-header" style="background:#FFFBEB;"><h3>Change Email</h3></div>
          <div class="card-body">
            <div style="display:flex;gap:8px;">
              <input type="email" id="new_email" placeholder="new@company.com" style="flex:1;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;">
              <button class="btn btn-primary btn-sm" onclick="changeEmail()">Update Email</button>
            </div>
            <div class="form-hint" style="margin-top:6px;">Note: Email change takes effect immediately with no verification.</div>
          </div>
        </div>

        <div class="card mb-4" style="border-color:#FDE68A;">
          <div class="card-header" style="background:#FFFBEB;"><h3>Change Password</h3></div>
          <div class="card-body">
            <div class="form-group"><label>New Password</label><input type="password" id="new_pass" placeholder="New password" style="max-width:300px;"></div>
            <div class="form-hint" style="margin-bottom:12px;">Current password is not required to change your password.</div>
            <button class="btn btn-primary btn-sm" onclick="changePassword()">Update Password</button>
          </div>
        </div>

        <div class="card">
          <div class="card-header"><h3>API Access</h3></div>
          <div class="card-body">
            <label style="font-size:12px;font-weight:600;margin-bottom:6px;display:block;">Your API Key</label>
            <div style="display:flex;gap:8px;">
              <input type="text" value="<%= user.api_key || 'Not set' %>" readonly style="flex:1;font-family:monospace;font-size:12px;background:#F9FAFB;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius);">
              <button class="btn btn-secondary btn-sm" onclick="navigator.clipboard.writeText(document.querySelector('[readonly]').value)">Copy</button>
            </div>
            <div class="form-hint">Use this key in the <code>X-API-Key</code> header for API requests.</div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<script>
function changeEmail() {
  fetch('/profile/<%= user.id %>/change-email',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({new_email:document.getElementById('new_email').value})})
    .then(r=>r.json()).then(d=>alert(d.message||d.error));
}
function changePassword() {
  fetch('/profile/<%= user.id %>/change-password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({new_password:document.getElementById('new_pass').value})})
    .then(r=>r.json()).then(d=>alert(d.message||d.error));
}
</script>
<%- include('partials/footer') %>
