<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Support Tickets</span>
      <div class="header-right">
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('new-ticket').style.display='block'">+ New Ticket</button>
        <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
      </div>
    </div>
    <div class="page-body">
      <div id="new-ticket" style="display:none;" class="card mb-4" style="max-width:560px;">
        <div class="card-header"><h3>Submit New Ticket</h3><button onclick="document.getElementById('new-ticket').style.display='none'" class="btn btn-secondary btn-sm">Cancel</button></div>
        <div class="card-body">
          <form action="/tickets" method="POST">
            <div class="form-group"><label>Subject<span class="form-required">*</span></label><input type="text" name="subject" required placeholder="Brief description of your issue"></div>
            <div class="form-row">
              <div class="form-group"><label>Priority</label><select name="priority"><option value="low">Low</option><option value="medium" selected>Medium</option><option value="high">High</option><option value="critical">Critical</option></select></div>
              <div class="form-group"><label>Category</label><select name="category"><option value="bug">Bug Report</option><option value="request">Feature Request</option><option value="billing">Billing</option><option value="general">General</option></select></div>
            </div>
            <div class="form-group"><label>Message<span class="form-required">*</span></label><textarea name="message" rows="4" required placeholder="Detailed description…"></textarea></div>
            <button type="submit" class="btn btn-primary">Submit Ticket</button>
          </form>
        </div>
      </div>
      <div class="card">
        <div class="table-wrapper">
          <table>
            <thead><tr><th>#</th><th>Subject</th><th>Category</th><th>Priority</th><th>Status</th><th>Created</th><th></th></tr></thead>
            <tbody>
              <% if (tickets.length === 0) { %>
                <tr><td colspan="7" class="text-center text-muted" style="padding:32px;">No tickets yet.</td></tr>
              <% } else { %>
              <% tickets.forEach(t => { %>
              <tr>
                <td style="color:var(--text-muted);font-size:12px;">#<%= t.id %></td>
                <td><a href="/tickets/<%= t.id %>" style="color:var(--accent);text-decoration:none;font-weight:600;"><%= t.subject.length>50?t.subject.slice(0,50)+'…':t.subject %></a></td>
                <td><span class="badge badge-gray"><%= t.category||'general' %></span></td>
                <td><span class="badge badge-<%= t.priority==='critical'?'danger':t.priority==='high'?'warning':'gray' %>"><%= t.priority %></span></td>
                <td><span class="badge badge-<%= t.status==='open'?'info':t.status==='resolved'?'success':'gray' %>"><%= t.status %></span></td>
                <td style="font-size:12px;color:var(--text-muted);"><%= new Date(t.created_at).toLocaleDateString() %></td>
                <td><a href="/tickets/<%= t.id %>" class="btn btn-secondary btn-sm">View</a></td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
