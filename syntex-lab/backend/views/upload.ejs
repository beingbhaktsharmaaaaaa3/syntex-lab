<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">File Manager</span>
      <div class="header-right"><a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a></div>
    </div>
    <div class="page-body">
      <div class="page-header"><h1>File Manager</h1><p>Upload and manage documents, images, and attachments.</p></div>
      <% if (success) { %><div class="alert alert-success alert-auto-dismiss"><%= success %></div><% } %>
      <% if (error)   { %><div class="alert alert-danger"><%= error %></div><% } %>
      <div class="grid-2" style="align-items:start;">
        <div class="card">
          <div class="card-header"><h3>Upload File</h3></div>
          <div class="card-body">
            <!-- VULNERABILITY: Server only checks file extension, not MIME type or magic bytes -->
            <!-- Bypass: rename shell.php to shell.php.jpg — extname() returns .jpg -->
            <form action="/upload" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label>Select File<span class="form-required">*</span></label>
                <input type="file" name="file" required style="padding:6px;">
                <div class="form-hint">Allowed: .jpg .jpeg .png .gif .pdf .doc .docx .txt .csv — Max 10MB</div>
              </div>
              <div class="form-group">
                <label class="form-check"><input type="checkbox" name="is_public"> Make file publicly accessible</label>
              </div>
              <button type="submit" class="btn btn-primary">Upload</button>
            </form>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h3>My Files</h3></div>
          <div class="table-wrapper">
            <% if (files.length === 0) { %>
              <div class="empty-state"><h3>No files yet</h3><p>Upload your first file above.</p></div>
            <% } else { %>
            <table>
              <thead><tr><th>Filename</th><th>Size</th><th>Public</th><th></th></tr></thead>
              <tbody>
                <% files.forEach(f => { %>
                <tr>
                  <td style="font-size:12px;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= f.original_name %></td>
                  <td style="font-size:12px;color:var(--text-muted);"><%= (f.file_size/1024).toFixed(1) %>KB</td>
                  <td><% if (f.is_public) { %><span class="badge badge-warning">Public</span><% } else { %><span class="badge badge-gray">Private</span><% } %></td>
                  <td>
                    <!-- VULNERABILITY: Path traversal in /download?file= parameter -->
                    <a href="/download?file=<%= f.stored_name %>" class="btn btn-secondary btn-sm">Download</a>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
