<%- include('partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Search</span>
      <div class="header-right">
        <a href="/profile/<%= user ? user.id : '' %>" class="header-user">
          <% if (user) { %><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div><% } %>
        </a>
      </div>
    </div>
    <div class="page-body">
      <div class="page-header"><h1>Search</h1></div>

      <div class="card mb-4">
        <div class="card-body">
          <form action="/search" method="GET" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <input type="text" name="q" value="<%= query %>" placeholder="Search products, posts, users…"
                   style="flex:1;min-width:200px;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;">
            <select name="type" style="padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;background:#fff;">
              <option value="all"      <%= type==='all'     ?'selected':'' %>>All</option>
              <option value="products" <%= type==='products'?'selected':'' %>>Products</option>
              <option value="posts"    <%= type==='posts'   ?'selected':'' %>>Knowledge Base</option>
              <option value="users"    <%= type==='users'   ?'selected':'' %>>Users</option>
            </select>
            <button type="submit" class="btn btn-primary">Search</button>
          </form>
        </div>
      </div>

      <% if (query) { %>
      <div class="mb-4" style="font-size:13px;color:var(--text-muted);">
        <%# VULNERABILITY: Reflected XSS — query rendered without HTML encoding %>
        <%# Payload: /search?q=<script>alert(document.cookie)</script> %>
        <%# Tool: dalfox url 'http://localhost:3000/search?q=test' %>
        Showing <strong><%= results.length %></strong> result(s) for: <strong><%- query %></strong>
      </div>

      <% if (results.length === 0) { %>
        <div class="empty-state">
          <h3>No results found</h3>
          <p>Try a different search term or category.</p>
        </div>
      <% } else { %>
        <div class="card">
          <div class="table-wrapper">
            <table>
              <thead><tr><th>Type</th><th>Title</th><th>Excerpt</th><th></th></tr></thead>
              <tbody>
                <% results.forEach(r => { %>
                <tr>
                  <td><span class="badge badge-<%= r.result_type==='product'?'info':r.result_type==='post'?'gray':'admin' %>"><%= r.result_type %></span></td>
                  <td style="font-weight:600;"><%= r.title %></td>
                  <td style="color:var(--text-muted);max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= r.excerpt %></td>
                  <td><a href="<%= r.url %>" class="btn btn-secondary btn-sm">View →</a></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
      <% } %>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
